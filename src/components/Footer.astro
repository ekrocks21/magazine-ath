---
/**
 * Site footer — 4-column grid: masthead + P.O. Box, magazine nav, ATH family,
 * colophon. Bottom rule with copyright + printer note + current issue badge.
 * Matches the prototype footer.
 */

const year = new Date().getFullYear();

const magazineLinks = [
  { label: 'Current Issue', href: '/issues/spring-2026' },
  { label: 'The Archive', href: '/archive' },
  { label: 'Subscribe', href: '/subscribe' },
  { label: 'Next Issue', href: '/next' },
];

const athLinks = [
  { label: 'abovethehook.com', href: 'https://abovethehook.com' },
  { label: 'ATH View — Live cams', href: 'https://harbor.abovethehook.com' },
  { label: 'The Blog', href: 'https://blog.abovethehook.com' },
  { label: 'YouTube · Instagram · Facebook', href: 'https://instagram.com/abovethehook' },
];

const colophonLinks = [
  { label: 'About the Lookout', href: '/about' },
  { label: 'Masthead & contributors', href: '/about#masthead' },
  { label: 'Typography & printing', href: '/about#colophon' },
  { label: 'Corrections', href: '/about#corrections' },
];
---

<footer style="background: var(--navy-dark); color: var(--on-dark-2); margin-top: 96px;">
  <div class="mag-rust-rule"></div>
  <div style="max-width: var(--max-wide); margin: 0 auto; padding: 56px 40px 40px;">
    <div class="footer-grid">
      <!-- Masthead column -->
      <div>
        <div
          style="font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--sand); margin-bottom: 8px;"
        >
          Above the Hook · Quarterly
        </div>
        <div
          style="font-family: var(--font-display); font-size: 28px; line-height: 1; color: #fff; letter-spacing: -0.015em; margin-bottom: 18px;"
        >
          The Local <em style="font-weight: 400; color: var(--sand-light);">Lookout</em>
        </div>
        <p
          style="font-family: var(--font-body); font-size: 14px; line-height: 1.6; color: var(--on-dark-3); max-width: 320px; margin-bottom: 18px;"
        >
          A quarterly magazine of Sandy Hook, New York Harbor, Highlands, and the Monmouth
          County coast. Published four times a year by Above the Hook.
        </p>
        <div
          style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand); margin-bottom: 6px;"
        >
          Way up North Jersey Shore
        </div>
        <div
          style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand);"
        >
          <a
            href="mailto:shop@abovethehook.com"
            style="color: var(--sand); text-decoration: none; border-bottom: 1px solid rgba(216,205,184,0.4);"
          >shop@abovethehook.com</a>
        </div>
      </div>

      <!-- Magazine nav -->
      <div>
        <div
          style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand); margin-bottom: 18px;"
        >
          The Magazine
        </div>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px;">
          {magazineLinks.map((l) => (
            <li>
              <a
                href={l.href}
                style="font-family: var(--font-body); font-size: 14px; color: var(--on-dark-2); text-decoration: none;"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- ATH family -->
      <div>
        <div
          style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand); margin-bottom: 18px;"
        >
          Above the Hook
        </div>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px;">
          {athLinks.map((l) => (
            <li>
              <a
                href={l.href}
                style="font-family: var(--font-body); font-size: 14px; color: var(--on-dark-2); text-decoration: none;"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Colophon -->
      <div>
        <div
          style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand); margin-bottom: 18px;"
        >
          Colophon
        </div>
        <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px;">
          {colophonLinks.map((l) => (
            <li>
              <a
                href={l.href}
                style="font-family: var(--font-body); font-size: 14px; color: var(--on-dark-2); text-decoration: none;"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom rule -->
    <div
      style="margin-top: 56px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;"
    >
      <div
        style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--sand);"
      >
        &copy; {year} Above the Hook · Printed in Highlands, New Jersey
      </div>
      <div
        style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--sand);"
      >
        Issue No. 02 · Spring 2026
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
