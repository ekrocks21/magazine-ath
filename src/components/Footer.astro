---
/**
 * Site footer — links to ATH family, colophon, mailing address.
 * Spec §4.1 / §5.
 */

const year = new Date().getFullYear();

const athLinks = [
  { label: 'abovethehook.com', href: 'https://abovethehook.com' },
  { label: 'harbor.abovethehook.com', href: 'https://harbor.abovethehook.com' },
  { label: 'blog.abovethehook.com', href: 'https://blog.abovethehook.com' },
];

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/abovethehook' },
  { label: 'YouTube', href: 'https://youtube.com/@abovethehookstudios' },
  { label: 'Facebook', href: 'https://facebook.com/abovethehook' },
];

const magazineLinks = [
  { label: 'Current Issue', href: '/issues/spring-2026' },
  { label: 'Archive', href: '/archive' },
  { label: 'About', href: '/about' },
  { label: 'RSS', href: '/rss.xml' },
];
---

<footer class="bg-[var(--color-navy)] text-[var(--color-cream)] mt-24">
  <hr class="rust-rule" />

  <div class="max-w-6xl mx-auto px-6 md:px-10 py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-4">
      <!-- Masthead column -->
      <div class="md:col-span-2">
        <p
          class="text-xs tracking-[0.25em] uppercase text-[var(--color-cream)]/60"
          style="font-family: var(--font-sans);"
        >
          Above the Hook
        </p>
        <p
          class="mt-2 text-2xl md:text-3xl leading-tight text-[var(--color-cream)]"
          style="font-family: var(--font-display); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
        >
          The Local Lookout
        </p>
        <p
          class="mt-4 text-sm leading-relaxed text-[var(--color-cream)]/70 max-w-sm"
          style="font-family: var(--font-body);"
        >
          The quarterly print magazine of Above the Hook. Coastal New Jersey,
          observed slowly.
        </p>
        <p
          class="mt-6 text-xs text-[var(--color-cream)]/55 not-italic"
          style="font-family: var(--font-sans);"
        >
          Atlantic Highlands, New Jersey<br />
          <a
            href="mailto:hello@abovethehook.com"
            class="underline underline-offset-2 decoration-[var(--color-rust)]/60 hover:text-[var(--color-cream)]"
            >hello@abovethehook.com</a
          >
        </p>
      </div>

      <!-- Magazine nav -->
      <div>
        <p
          class="text-[0.65rem] tracking-[0.25em] uppercase text-[var(--color-cream)]/60 mb-4"
          style="font-family: var(--font-sans);"
        >
          The Magazine
        </p>
        <ul class="list-none m-0 p-0 space-y-2">
          {
            magazineLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-[var(--color-cream)]/80 hover:text-[var(--color-cream)] no-underline"
                  style="font-family: var(--font-sans);"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- ATH family links + social -->
      <div>
        <p
          class="text-[0.65rem] tracking-[0.25em] uppercase text-[var(--color-cream)]/60 mb-4"
          style="font-family: var(--font-sans);"
        >
          Above the Hook
        </p>
        <ul class="list-none m-0 p-0 space-y-2">
          {
            athLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-[var(--color-cream)]/80 hover:text-[var(--color-cream)] no-underline"
                  style="font-family: var(--font-sans);"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>

        <p
          class="text-[0.65rem] tracking-[0.25em] uppercase text-[var(--color-cream)]/60 mt-8 mb-4"
          style="font-family: var(--font-sans);"
        >
          Follow
        </p>
        <ul class="list-none m-0 p-0 space-y-2">
          {
            socialLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-[var(--color-cream)]/80 hover:text-[var(--color-cream)] no-underline"
                  style="font-family: var(--font-sans);"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Colophon -->
    <div
      class="mt-16 pt-8 border-t border-[var(--color-cream)]/10 flex flex-col md:flex-row md:items-end md:justify-between gap-4"
    >
      <p
        class="text-[0.65rem] tracking-[0.2em] uppercase text-[var(--color-cream)]/45 leading-relaxed"
        style="font-family: var(--font-sans);"
      >
        Set in Fraunces, Source Serif 4, and Inter.<br />
        Published quarterly.
      </p>
      <p
        class="text-[0.65rem] tracking-[0.2em] uppercase text-[var(--color-cream)]/45"
        style="font-family: var(--font-sans);"
      >
        &copy; {year} Above the Hook
      </p>
    </div>
  </div>
</footer>
