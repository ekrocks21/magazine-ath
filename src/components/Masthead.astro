---
/**
 * Three-zone masthead: left nav | centered wordmark | right CTA.
 *
 * On pages with data-hero-fullbleed on <body> the header begins
 * position:fixed + transparent, overlaying the full-bleed hero.
 * An IntersectionObserver watches #hero-sentinel (placed at the
 * bottom of the hero section) and adds .is-solid once the hero
 * scrolls out of view, triggering the navy background.
 *
 * On all other pages the header renders as position:sticky with
 * the standard navy background — no JS needed.
 */

import { getCollection } from 'astro:content';

const NOW = Date.now();
const allIssues = await getCollection('issues');
const currentIssue = allIssues
  .filter((i) => (i.data.publish_date?.valueOf() ?? 0) <= NOW)
  .sort(
    (a, b) =>
      (b.data.publish_date?.valueOf() ?? 0) -
      (a.data.publish_date?.valueOf() ?? 0),
  )[0];
const currentIssueHref = currentIssue
  ? `/issues/${currentIssue.id.replace(/\.md$/, '')}`
  : '/archive';

const currentPath = Astro.url.pathname;

function isActiveFor(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}

const leftNav = [
  { label: 'Current Issue', href: currentIssueHref },
  { label: 'Archive', href: '/archive' },
  { label: 'About', href: '/about' },
];
---

<header class="mag-masthead">
  <div class="mag-masthead-inner">

    <nav class="mag-nav-left" aria-label="Primary">
      {leftNav.map((item) => (
        <a
          href={item.href}
          class={isActiveFor(item.href) ? 'is-active' : ''}
          aria-current={isActiveFor(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a href="/" class="mag-wordmark" aria-label="The Local Lookout — home">
      <span class="mag-wordmark-sup">Above the Hook · Quarterly</span>
      <span class="mag-wordmark-main">The Local <em>Lookout</em></span>
    </a>

    <nav class="mag-nav-right" aria-label="Account">
      <a href="/next" class="mag-nav-secondary">Next Issue</a>
      {/* Subscribe chip swaps to Account after /api/me responds. */}
      <a href="/subscribe" class="mag-subscribe-btn" data-mag-subscribe-cta>Subscribe</a>
      <a href="/account" class="mag-subscribe-btn" data-mag-account-cta hidden>Account</a>
    </nav>

  </div>
  <div class="mag-rust-rule"></div>
</header>

<script>
  /* ── Transparent-hero scroll logic ──────────────────────────────────
     Only active when body carries data-hero-fullbleed (home page).
     IntersectionObserver watches #hero-sentinel (zero-height div at
     the bottom of the hero section). While the sentinel is visible the
     masthead stays transparent; once it scrolls out we add .is-solid. */
  (function () {
    var body = document.body;
    var masthead = document.querySelector('.mag-masthead');
    if (!body || !masthead) return;

    if (body.hasAttribute('data-hero-fullbleed')) {
      var sentinel = document.getElementById('hero-sentinel');
      if (sentinel) {
        var observer = new IntersectionObserver(
          function (entries) {
            masthead.classList.toggle('is-solid', !entries[0].isIntersecting);
          },
          { threshold: 0 },
        );
        observer.observe(sentinel);
      }
    }

    /* ── Session / paywall logic (unchanged) ───────────────────────── */
    var subscribeCta = document.querySelector('[data-mag-subscribe-cta]');
    var accountCta = document.querySelector('[data-mag-account-cta]');

    fetch('/api/me', { credentials: 'same-origin', cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data || !data.signedIn) return;
        if (subscribeCta && accountCta) {
          subscribeCta.setAttribute('hidden', '');
          accountCta.removeAttribute('hidden');
        }
        var entitlements = data.entitlements || [];
        unlockGatedCards(entitlements);
        applySubscriberPricing(entitlements);
      })
      .catch(function () { /* offline / Worker not in front — keep defaults */ });

    function applySubscriberPricing(entitlements) {
      var isPrint = false;
      for (var i = 0; i < entitlements.length; i++) {
        if (entitlements[i].tier === 'print') { isPrint = true; break; }
      }
      if (!isPrint) return;
      var priceEls = document.querySelectorAll('[data-single-issue-price]');
      for (var j = 0; j < priceEls.length; j++) {
        priceEls[j].textContent = '$50';
      }
    }

    function unlockGatedCards(entitlements) {
      var cards = document.querySelectorAll('[data-access="subscriber"][data-article-issue]');
      if (!cards.length) return;
      for (var i = 0; i < cards.length; i++) {
        var card = cards[i];
        var issueSlug = card.getAttribute('data-article-issue');
        if (!hasAccess(entitlements, issueSlug)) continue;
        var lockedChip = card.querySelector('[data-chip-state="locked"]');
        var unlockedChip = card.querySelector('[data-chip-state="unlocked"]');
        if (lockedChip) lockedChip.setAttribute('hidden', '');
        if (unlockedChip) unlockedChip.removeAttribute('hidden');
      }
    }

    function hasAccess(entitlements, issueSlug) {
      for (var i = 0; i < entitlements.length; i++) {
        var tier = entitlements[i].tier;
        if (tier === 'digital' || tier === 'print') return true;
        if (tier === 'issue:' + issueSlug) return true;
      }
      return false;
    }
  })();
</script>
