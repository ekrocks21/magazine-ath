---
/**
 * Navy masthead with two-line wordmark (Above the Hook · Quarterly /
 * The Local <em>Lookout</em>), primary nav, subscribe chip, thin rust
 * divider beneath. Matches the prototype `.mag-masthead`.
 *
 * "Current Issue" resolves dynamically to the latest published issue so
 * the link tracks forward as new issues ship.
 */

import { getCollection } from 'astro:content';

interface NavItem {
  label: string;
  href: string;
}

const NOW = Date.now();
const allIssues = await getCollection('issues');
const currentIssue = allIssues
  .filter((i) => (i.data.publish_date?.valueOf() ?? 0) <= NOW)
  .sort(
    (a, b) =>
      (b.data.publish_date?.valueOf() ?? 0) -
      (a.data.publish_date?.valueOf() ?? 0),
  )[0];
const currentIssueHref = currentIssue
  ? `/issues/${currentIssue.id.replace(/\.md$/, '')}`
  : '/archive';

const nav: NavItem[] = [
  { label: 'Current Issue', href: currentIssueHref },
  { label: 'Archive', href: '/archive' },
  { label: 'Next Issue', href: '/next' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;

function isActiveFor(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="mag-masthead">
  <div class="mag-masthead-inner">
    <a href="/" class="mag-wordmark" aria-label="The Local Lookout — home">
      <span class="mag-wordmark-sup">Above the Hook · Quarterly</span>
      <span class="mag-wordmark-main">The Local <em>Lookout</em></span>
    </a>

    <nav class="mag-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class={isActiveFor(item.href) ? 'is-active' : ''}
          aria-current={isActiveFor(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
      {/* Default Subscribe chip is swapped to Account by the IIFE below
          if /api/me reports an active session. Rendered both ways so
          the cold page renders correctly when the Worker isn't in front. */}
      <a href="/subscribe" class="mag-subscribe-btn" data-mag-subscribe-cta>Subscribe</a>
      <a href="/api/account" class="mag-subscribe-btn" data-mag-account-cta hidden>Account</a>
    </nav>
  </div>
  <div class="mag-rust-rule"></div>
</header>

<script>
  /* Swap the Subscribe chip for Account when a session cookie is
     present. /api/me is served by the paywall Worker and returns
     { signedIn: true, email, entitlements[] } when the reader has a
     valid magazine_session cookie. */
  (function () {
    var subscribeCta = document.querySelector('[data-mag-subscribe-cta]');
    var accountCta = document.querySelector('[data-mag-account-cta]');
    if (!subscribeCta || !accountCta) return;
    fetch('/api/me', { credentials: 'same-origin', cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (data && data.signedIn) {
          subscribeCta.setAttribute('hidden', '');
          accountCta.removeAttribute('hidden');
        }
      })
      .catch(function () { /* offline / Worker not in front — keep defaults */ });
  })();
</script>
