---
/**
 * Editorial pull quote — larger display serif, rust accent rule.
 * Spec §4.4 / §10 component inventory.
 *
 * Usage inside article body (via a later remark plugin or manual wrap):
 *   <PullQuote attribution="— Robert Juet, 1609">
 *     This is a very good Land to fall with, and a pleasant Land to see.
 *   </PullQuote>
 */

interface Props {
  attribution?: string;
  class?: string;
}

const { attribution, class: className = '' } = Astro.props;
---

<figure class={`my-16 md:my-20 ${className}`.trim()}>
  <div class="flex gap-6 md:gap-8">
    <!-- Thin rust accent rule on the left -->
    <span
      class="flex-shrink-0 w-[2px] bg-[var(--color-rust)] self-stretch"
      aria-hidden="true"
    ></span>

    <blockquote
      class="text-2xl md:text-3xl lg:text-4xl leading-[1.25] text-[var(--color-navy)] italic"
      style="font-family: var(--font-display); font-variation-settings: 'opsz' 96, 'SOFT' 50, 'WONK' 0;"
    >
      <slot />
    </blockquote>
  </div>

  {
    attribution && (
      <figcaption
        class="mt-6 ml-8 md:ml-10 text-[0.7rem] tracking-[0.25em] uppercase text-[var(--color-muted)]"
        style="font-family: var(--font-mono);"
      >
        {attribution}
      </figcaption>
    )
  }
</figure>
