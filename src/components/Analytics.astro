---
/**
 * Analytics — Cloudflare Web Analytics beacon.
 *
 * Set PUBLIC_CF_WEB_ANALYTICS_TOKEN in Netlify environment variables to
 * the token generated at dash.cloudflare.com → Analytics → Web Analytics.
 * Leave unset in dev/preview to skip the beacon entirely.
 */

const token = import.meta.env.PUBLIC_CF_WEB_ANALYTICS_TOKEN;
---

{token && (
  <script
    is:inline
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon={`{"token": "${token}"}`}
  ></script>
)}
