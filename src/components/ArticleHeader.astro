---
/**
 * Article page header — pillar tag, display headline, dek, byline.
 * Spec §4.4.
 *
 * Rendered above the hero image and body.
 */

interface Props {
  title: string;
  dek?: string;
  author: string;
  byline?: string;
  pillar: string;
  publishDate?: Date;
  /** "10 min read" string, computed by the parent from word_count. */
  readingTime?: string;
}

const { title, dek, author, byline, pillar, publishDate, readingTime } =
  Astro.props;

// Turn snake_case pillar key into display label: "Historical Storytelling"
const pillarLabel = pillar
  .split('_')
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');

const dateLabel = publishDate
  ? publishDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : undefined;
---

<header class="max-w-3xl mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-10">
  <!-- Pillar tag -->
  <div class="mb-8">
    <span class="tag-pill">{pillarLabel}</span>
  </div>

  <!-- Headline -->
  <h1
    class="text-4xl md:text-6xl lg:text-7xl leading-[1.04] text-balance"
    style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 0;"
  >
    {title}
  </h1>

  <!-- Dek -->
  {
    dek && (
      <p
        class="mt-6 md:mt-8 text-xl md:text-2xl leading-snug text-[var(--color-taupe)] italic max-w-2xl"
        style="font-family: var(--font-body);"
      >
        {dek}
      </p>
    )
  }

  <!-- Byline + date + read time -->
  <div
    class="mt-10 md:mt-12 pt-6 border-t border-[var(--color-ink)]/10 flex flex-wrap items-baseline gap-x-4 gap-y-2 text-xs tracking-[0.2em] uppercase text-[var(--color-taupe)]"
    style="font-family: var(--font-sans);"
  >
    <span>By {byline ?? author}</span>
    {dateLabel && <span aria-hidden="true">·</span>}
    {dateLabel && <span>{dateLabel}</span>}
    {readingTime && <span aria-hidden="true">·</span>}
    {readingTime && <span>{readingTime}</span>}
  </div>
</header>
