---
/**
 * Renders the editorial illustration associated with an article slug.
 *
 * Uses the 17-plate ATH thumbnail library in /public/illustrations/thumbs/.
 * Each plate is 1200x700 in the house style (navy/cream/rust, limited
 * palette, archival texture) — sourced from the Claude Design handoff.
 *
 * If no mapping matches, a neutral placeholder renders so the frame
 * never collapses.
 */

interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;

// Article slug → thumbnail filename.
// Library inventory (see /public/illustrations/thumbs/):
//   container-ship, dock-dusk, ferry-to-nyc, fishing-boat, fort-hancock,
//   harbor-chart, highlands-bridge, highlands-night, lobster-boat,
//   nyc-skyline, overlook, regatta, sailboat-race, sandy-hook-beach,
//   sandy-hook-lighthouse, twin-lights, winter-cargo
const MAP: Record<string, string> = {
  // Spring 2026 — historical / cartographic
  'a-very-good-land-to-fall-with': '/illustrations/thumbs/overlook.svg',
  'thirteen-shillings': '/illustrations/thumbs/harbor-chart.svg',
  'editors-letter': '/illustrations/thumbs/sandy-hook-beach.svg',

  // Future / placeholders referenced elsewhere in the site
  'the-house-that-stayed': '/illustrations/thumbs/fort-hancock.svg',
  'building-600': '/illustrations/thumbs/fort-hancock.svg',
  strandings: '/illustrations/thumbs/sandy-hook-beach.svg',
  'bahrs-landing': '/illustrations/thumbs/fishing-boat.svg',
  'goat-hill': '/illustrations/thumbs/highlands-bridge.svg',

  // Winter 2026 (articles with real hero photos skip this mapping
  // via index.astro's hero_image preference; kept for fallback)
  'a-letter-from-the-hilltop': '/illustrations/thumbs/overlook.svg',
  'the-river-froze': '/illustrations/thumbs/winter-cargo.svg',
  'the-year-the-river-remembered': '/illustrations/thumbs/ferry-to-nyc.svg',
  'coming-to-the-screen': '/illustrations/thumbs/twin-lights.svg',
  'whats-up-next': '/illustrations/thumbs/highlands-night.svg',
};

const src = MAP[slug];
---

{
  src ? (
    <img src={src} alt={title} loading="lazy" decoding="async" />
  ) : (
    <svg
      viewBox="0 0 1200 700"
      preserveAspectRatio="xMidYMid slice"
      width="100%"
      height="100%"
      role="img"
      aria-label={title}
    >
      <defs>
        <linearGradient id={`ca-fallback-${slug}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#2A4470" />
          <stop offset="1" stop-color="#10192B" />
        </linearGradient>
      </defs>
      <rect width="1200" height="700" fill={`url(#ca-fallback-${slug})`} />
      <circle cx="960" cy="224" r="54" fill="#C4583E" opacity="0.7" />
      <path
        d="M0 490 Q 300 420 600 458 Q 900 490 1200 448 L 1200 700 L 0 700 Z"
        fill="#1A1208"
      />
    </svg>
  )
}
