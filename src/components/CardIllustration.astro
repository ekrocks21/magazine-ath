---
/**
 * Renders the 400x300 editorial illustration associated with an article.
 *
 * Illustrations live under /public/illustrations/ and are mapped by the
 * article's filename slug. If no illustration matches, a neutral placeholder
 * SVG is rendered so the 4:3 frame never collapses.
 */

interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;

// slug → illustration filename (in /public/illustrations/)
const MAP: Record<string, string> = {
  // Spring 2026
  'a-very-good-land-to-fall-with': '/illustrations/05-juet-hills.svg',
  'thirteen-shillings': '/illustrations/06-hartshorne-map.svg',
  'feature-a-very-good-land-to-fall-with': '/illustrations/05-juet-hills.svg',
  'feature-thirteen-shillings': '/illustrations/06-hartshorne-map.svg',
  'the-house-that-stayed': '/illustrations/07-building-600-house.svg',
  'building-600': '/illustrations/07-building-600-house.svg',
  strandings: '/illustrations/08-humpback-stranding.svg',
  'bahrs-landing': '/illustrations/09-bahrs-landing.svg',
  'goat-hill': '/illustrations/10-goat-hill.svg',
  // Winter 2026
  lighthouse: '/illustrations/11-winter-lighthouse.svg',
  'sandy-hook-lighthouse': '/illustrations/11-winter-lighthouse.svg',
  bunkers: '/illustrations/12-winter-weapons-bunkers.svg',
  'fort-hancock': '/illustrations/12-winter-weapons-bunkers.svg',
  'ice-floes': '/illustrations/13-winter-ice-floes.svg',
  'winter-diner': '/illustrations/14-winter-diner.svg',
  'route-36': '/illustrations/15-winter-route-36.svg',
};

const src = MAP[slug];
---

{
  src ? (
    <img src={src} alt={title} loading="lazy" decoding="async" />
  ) : (
    <svg
      viewBox="0 0 400 300"
      preserveAspectRatio="xMidYMid slice"
      width="100%"
      height="100%"
      role="img"
      aria-label={title}
    >
      <defs>
        <linearGradient id={`ca-fallback-${slug}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#2A4470" />
          <stop offset="1" stop-color="#10192B" />
        </linearGradient>
      </defs>
      <rect width="400" height="300" fill={`url(#ca-fallback-${slug})`} />
      <circle cx="320" cy="96" r="18" fill="#C4583E" opacity="0.7" />
      <path
        d="M0 210 Q 100 180 200 196 Q 300 210 400 192 L 400 300 L 0 300 Z"
        fill="#1A1208"
      />
    </svg>
  )
}
