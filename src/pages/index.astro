---
/**
 * Landing — /
 *
 * Eight sections after the masthead (injected via BaseLayout):
 *   1. Story-forward hero (dual-color headline, info strip, tilted cover)
 *   2. Editor's letter excerpt, centered, 2-column with drop cap
 *   3. "In this issue" — 4-col editorial card grid with illustrations
 *   4. Subscribe tiers (visual-only in Phase 1)
 *   5. 5-col archive strip
 *   6. Coming Next card
 *   7. Footer (injected via BaseLayout)
 */

import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CardIllustration from '../components/CardIllustration.astro';
import CoverImage from '../components/CoverImage.astro';
import StructuredData from '../components/StructuredData.astro';
import { articleRoute } from '../utils/article-route';
import {
  siteWebSite,
  siteOrganization,
} from '../utils/structured-data';

const includeDrafts =
  import.meta.env.PUBLIC_INCLUDE_DRAFTS === 'true' ||
  import.meta.env.DEV === true;

const issues = (await getCollection('issues')).sort((a, b) => {
  const da = a.data.publish_date?.valueOf() ?? 0;
  const db = b.data.publish_date?.valueOf() ?? 0;
  return db - da;
});

// Split by publish_date vs. today: "current" is the most recent issue whose
// publish_date is in the past (or today); "next" is the nearest future issue.
const NOW = Date.now();
const publishedIssues = issues.filter(
  (i) => (i.data.publish_date?.valueOf() ?? 0) <= NOW,
);
const futureIssues = issues
  .filter((i) => (i.data.publish_date?.valueOf() ?? 0) > NOW)
  .sort(
    (a, b) =>
      (a.data.publish_date?.valueOf() ?? 0) -
      (b.data.publish_date?.valueOf() ?? 0),
  );

const current = publishedIssues[0] ?? issues[0];
const currentSlug = current.id.replace(/\.md$/, '');
const currentData = current.data;

const nextIssue = futureIssues[0];
const nextSlug = nextIssue?.id.replace(/\.md$/, '');
const nextData = nextIssue?.data;
const nextNumber = nextData
  ? String(nextData.issue_number).padStart(2, '0')
  : '03';
const nextSeasonLabel = nextData
  ? nextData.season.charAt(0).toUpperCase() + nextData.season.slice(1)
  : 'Summer';
const nextPublishLabel = nextData?.publish_date
  ? new Date(nextData.publish_date).toLocaleDateString('en-US', {
      month: 'long',
      year: 'numeric',
      timeZone: 'UTC',
    })
  : 'July 2026';

const allArticles = await getCollection('articles', ({ data }) =>
  includeDrafts ? true : data.status !== 'draft',
);

const currentArticles = allArticles.filter(
  (a) => a.data.issue === currentSlug,
);

const editorsLetter = currentArticles.find((a) => a.data.type === 'editors_letter');

const featured = currentArticles
  .filter((a) => a.id !== editorsLetter?.id)
  .slice(0, 4);

// First article drives the hero headline (split on last period for em).
const heroArticle = featured[0] ?? editorsLetter;
const heroTitle = heroArticle?.data.title ?? currentData.theme ?? currentData.title;
const heroSlug = heroArticle ? articleRoute(heroArticle).articleSlug : '';

// Split hero title into two chunks for dual-color treatment.
function splitHeroTitle(t: string): { head: string; tail: string } {
  // Prefer splitting on " to " (as in "A very good land to fall with").
  const idx = t.toLowerCase().lastIndexOf(' to ');
  if (idx > 0) return { head: t.slice(0, idx + 1), tail: t.slice(idx + 1) + '.' };
  const words = t.split(/\s+/);
  if (words.length > 4) {
    const pivot = Math.ceil(words.length * 0.6);
    return { head: words.slice(0, pivot).join(' ') + ' ', tail: words.slice(pivot).join(' ') + '.' };
  }
  return { head: t + ' ', tail: '' };
}
const heroSplit = splitHeroTitle(heroTitle);

// Editor's letter excerpt — 2 body paragraphs
let letterParagraphs: string[] = [];
if (editorsLetter) {
  const raw = editorsLetter.body ?? '';
  const withoutHeading = raw.replace(/^#\s.*$/m, '').trim();
  letterParagraphs = withoutHeading
    .split(/\n\s*\n/)
    .map((p) => p.trim())
    .filter((p) => p && !p.startsWith('#') && !p.startsWith('*—'))
    .slice(0, 2);
}

const editorsLetterSlug = editorsLetter
  ? articleRoute(editorsLetter).articleSlug
  : '';

const authorsLabel = editorsLetter?.data.byline
  ? editorsLetter.data.byline.replace(/^Eric,.*$/, 'Eric')
  : editorsLetter?.data.author ?? 'Eric';

const editorsLetterDate = editorsLetter?.data.publication_date
  ? new Date(editorsLetter.data.publication_date).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
    })
  : 'April 1';

// Past issues (skip current; exclude future)
const pastIssues = publishedIssues.slice(1);
const currentNumber = String(currentData.issue_number).padStart(2, '0');

// Archive strip shows this year's four seasonal issues in order:
// Winter, Spring, Summer, Fall. Each carries a status tag:
//   past    — already shipped
//   current — most recently published issue (pops on the strip)
//   next    — the soonest upcoming issue
//   later   — future issues further out than "next"
// Current-year filter uses the issue's `year` frontmatter field.
const ARCHIVE_STRIP_SLOTS = 4;
const CURRENT_YEAR = new Date().getFullYear();

const archiveStripEntries = [...issues]
  .filter((i) => i.data.year === CURRENT_YEAR)
  .sort((a, b) => (a.data.issue_number ?? 0) - (b.data.issue_number ?? 0))
  .slice(0, ARCHIVE_STRIP_SLOTS)
  .map((issue) => {
    const isFuture = (issue.data.publish_date?.valueOf() ?? 0) > NOW;
    const isCurrent = !isFuture && issue.id === current.id;
    const status: 'past' | 'current' | 'future' = isFuture
      ? 'future'
      : isCurrent
        ? 'current'
        : 'past';
    return { issue, status };
  });

// Among the "future" cards, the soonest one is "next"; any after it
// are "later". This lets the UI distinguish what's actively up next
// vs. what's further out on the calendar.
const firstFutureIdx = archiveStripEntries.findIndex((e) => e.status === 'future');
const archiveStripCards = archiveStripEntries.map((entry, idx) => {
  if (entry.status !== 'future') return { ...entry, variant: entry.status };
  const variant: 'next' | 'later' = idx === firstFutureIdx ? 'next' : 'later';
  return { ...entry, variant };
});

/**
 * Format a ship_date for the archive strip. Returns either
 * "SHIPPED MAR 31, 2026" (past) or "ANTICIPATED JUN 30" (future).
 * Year is omitted on anticipated dates when they're in the current
 * year to keep the label compact.
 */
function formatShipLabel(date: Date | undefined, isFuture: boolean): string | null {
  if (!date) return null;
  const month = date.toLocaleDateString('en-US', { month: 'short' });
  const day = date.getDate();
  const year = date.getFullYear();
  if (isFuture) {
    return year === CURRENT_YEAR
      ? `Anticipated ${month} ${day}`
      : `Anticipated ${month} ${day}, ${year}`;
  }
  return `Shipped ${month} ${day}, ${year}`;
}

// Pillar → kicker label
function pillarLabel(p: string): string {
  return p.replace(/_/g, ' ').toUpperCase();
}

// Status → meta word
const statusWord = {
  planning: 'In planning',
  in_production: 'In production',
  published: 'Published',
  archived: 'Archived',
}[currentData.status] ?? 'Spring 2026';
---

<BaseLayout
  title="The Local Lookout"
  description="The quarterly print magazine of Above the Hook. Coastal New Jersey, observed slowly."
  ogImage="/og/default.png"
>
  <StructuredData data={[siteWebSite(), siteOrganization()]} slot="head" />
  <!-- ── 1. Story-forward hero ───────────────────────────────────── -->
  <section style="padding: 72px 0 96px;">
    <div class="mag-container hero-grid">
      <div>
        <div class="meta-dotted" style="margin-bottom: 28px;">
          Issue No. {currentNumber}<span class="dot">·</span>Spring 2026<span class="dot">·</span>
          <span class="rust">{statusWord}</span>
        </div>

        <h1
          style="font-family: var(--font-display); font-weight: 700; font-size: clamp(3rem, 6.4vw, 5.2rem); line-height: 1.02; letter-spacing: -0.025em; color: var(--ink); margin-bottom: 28px;"
        >
          {heroSplit.head}
          <em style="font-weight: 400; color: var(--rust);">{heroSplit.tail}</em>
        </h1>

        <p
          style="font-family: var(--font-display); font-style: italic; font-size: 20px; line-height: 1.5; color: var(--ink-soft); max-width: 520px; margin-bottom: 40px;"
        >
          The return of the ospreys. Thirteen shillings paid to the Lenape in
          1680. The house that stayed. A humpback at Gunnison Beach. The second
          issue of The Local Lookout.
        </p>

        <div style="display: flex; gap: 16px; flex-wrap: wrap;">
          <a href={`/issues/${currentSlug}`} class="btn-primary">
            Read the issue <span class="arrow">→</span>
          </a>
          {heroSlug && (
            <a href={`/issues/${currentSlug}/${heroSlug}`} class="btn-ghost">
              Preview the feature
            </a>
          )}
        </div>

        <div
          style="margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--sand); display: flex; gap: 48px; flex-wrap: wrap;"
        >
          <div>
            <div
              style="font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); margin-bottom: 4px;"
            >
              Publishing
            </div>
            <div
              style="font-family: var(--font-display); font-size: 18px; color: var(--ink); letter-spacing: -0.01em;"
            >
              Quarterly
            </div>
          </div>
          <div>
            <div
              style="font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); margin-bottom: 4px;"
            >
              From
            </div>
            <div
              style="font-family: var(--font-display); font-size: 18px; color: var(--ink); letter-spacing: -0.01em;"
            >
              Highlands, NJ
            </div>
          </div>
          <div>
            <div
              style="font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); margin-bottom: 4px;"
            >
              Founded
            </div>
            <div
              style="font-family: var(--font-display); font-size: 18px; color: var(--ink); letter-spacing: -0.01em;"
            >
              Winter 2026
            </div>
          </div>
        </div>
      </div>

      <div style="position: relative; padding-left: 24px;" class="hero-cover">
        <div
          class="issue-cover"
          style="width: 100%; max-width: 420px; margin-left: auto; transform: rotate(-1.2deg);"
        >
          {currentData.cover_image ? (
            <CoverImage
              src={currentData.cover_image}
              alt={currentData.cover_image_alt ?? `${currentData.title} cover`}
              widths={[360, 560, 720, 960]}
              sizes="(min-width: 900px) 420px, 80vw"
              loading="eager"
            />
          ) : (
            <svg viewBox="0 0 420 560" role="img" aria-label="Spring 2026 cover" style="display:block; width:100%; height:auto; background: var(--paper);">
              <rect width="420" height="560" fill="#FDFAF5" />
              <path d="M0 330 L70 304 L160 292 L260 286 L340 292 L420 302 L420 410 L0 410 Z" fill="#8B3A2A" opacity="0.12" />
              <circle cx="330" cy="180" r="28" fill="#C4583E" opacity="0.35" />
              <text x="210" y="110" text-anchor="middle" font-family="'DM Mono', monospace" font-size="11" letter-spacing="4" fill="#7A6F5F">ABOVE THE HOOK · QUARTERLY</text>
              <text x="210" y="250" text-anchor="middle" font-family="'Playfair Display', serif" font-size="46" font-weight="700" fill="#1A1208">The Local</text>
              <text x="210" y="310" text-anchor="middle" font-family="'Playfair Display', serif" font-size="46" font-weight="400" font-style="italic" fill="#8B3A2A">Lookout</text>
              <rect x="170" y="330" width="80" height="2" fill="#8B3A2A" />
              <text x="210" y="390" text-anchor="middle" font-family="'DM Mono', monospace" font-size="11" letter-spacing="3" fill="#7A6F5F">ISSUE NO. 02 · SPRING 2026</text>
              <text x="210" y="490" text-anchor="middle" font-family="'Playfair Display', serif" font-size="22" font-style="italic" fill="#3D3020">{currentData.theme ?? 'Return'}</text>
            </svg>
          )}
        </div>
        <div
          style="position: absolute; right: -20px; top: -14px; background: var(--rust); color: #fff; padding: 8px 14px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; transform: rotate(2deg); box-shadow: 0 6px 16px rgba(139,58,42,0.3);"
        >
          {statusWord}
        </div>
      </div>
    </div>
  </section>

  <!-- ── 2. Editor's letter ──────────────────────────────────────── -->
  {editorsLetter && letterParagraphs.length > 0 && (
    <section
      style="background: var(--cream-dark); padding: 88px 0; border-top: 1px solid var(--sand-light); border-bottom: 1px solid var(--sand-light);"
    >
      <div class="mag-container-narrow">
        <div class="meta-dotted" style="margin-bottom: 20px; text-align: center;">
          Letter from the Hilltop<span class="dot">·</span>Spring 2026<span class="dot">·</span>Free to read
        </div>
        <h2
          style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.8rem); text-align: center; letter-spacing: -0.02em; color: var(--ink); font-weight: 700; margin-bottom: 8px;"
        >
          {editorsLetter.data.title}
        </h2>
        <div
          style="text-align: center; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 48px;"
        >
          By {authorsLabel}<span style="margin: 0 0.5em; color: var(--sand);">·</span>{editorsLetterDate}
        </div>
        <div class="letter-grid">
          {letterParagraphs.map((p, i) => (
            <p
              style={`font-family: var(--font-body); font-size: 17px; line-height: 1.75; color: ${i === 0 ? 'var(--ink)' : 'var(--ink-soft)'};`}
            >
              {i === 0 && (
                <span
                  style="font-family: var(--font-display); font-size: 58px; font-weight: 700; float: left; line-height: 0.8; margin: 8px 10px 0 0; color: var(--rust);"
                >
                  {p.charAt(0)}
                </span>
              )}
              {i === 0 ? p.slice(1) : p}
            </p>
          ))}
        </div>
        <div style="text-align: center; margin-top: 36px;">
          <a
            href={`/issues/${currentSlug}/${editorsLetterSlug}`}
            class="btn-link"
          >
            Continue reading — free
            <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M4 10h12M11 5l5 5-5 5" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ── 3. In this issue — 4-col ed-card grid ────────────────────── -->
  {featured.length > 0 && (
    <section style="padding: 96px 0 72px;">
      <div class="mag-container">
        <div
          style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 48px; border-bottom: 1px solid var(--sand); padding-bottom: 20px; gap: 24px; flex-wrap: wrap;"
        >
          <div>
            <div class="meta-dotted" style="margin-bottom: 8px;">In this issue</div>
            <h2
              style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.8rem); letter-spacing: -0.02em; font-weight: 700;"
            >
              {featured.length === 1 ? 'One story to start.' : `${['','One','Two','Three','Four','Five','Six','Seven'][featured.length] || featured.length} stories, one free.`}
            </h2>
          </div>
          <a href={`/issues/${currentSlug}`} class="btn-link">
            Full table of contents
            <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M4 10h12M11 5l5 5-5 5" />
            </svg>
          </a>
        </div>

        <div class="ed-card-grid">
          {featured.map((a, i) => {
            const { articleSlug } = articleRoute(a);
            const isFree = a.data.access === 'free' || i === 0;
            const readingMin = Math.max(1, Math.round((a.data.word_count ?? 0) / 220));
            return (
              <a
                href={`/issues/${currentSlug}/${articleSlug}`}
                class="ed-card"
                data-access={isFree ? 'free' : 'subscriber'}
                data-article-issue={currentSlug}
              >
                <div class="ed-card-img">
                  {isFree ? (
                    <div class="free-chip">Free</div>
                  ) : (
                    <>
                      <div class="lock-chip" data-chip-state="locked">
                        <svg width="10" height="10" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                          <path d="M4 7V5a4 4 0 0 1 8 0v2h1v8H3V7h1zm2 0h4V5a2 2 0 1 0-4 0v2z" />
                        </svg>
                        Subscriber
                      </div>
                      <div class="lock-chip lock-chip--unlocked" data-chip-state="unlocked" hidden>
                        <svg width="10" height="10" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                          <path d="M3 8.5l3.2 3.2L13 5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Unlocked
                      </div>
                    </>
                  )}
                  {a.data.hero_image ? (
                    <Image
                      src={a.data.hero_image}
                      alt={a.data.hero_image_alt ?? a.data.title}
                      widths={[320, 480, 640, 800]}
                      sizes="(min-width: 1200px) 300px, (min-width: 900px) 22vw, (min-width: 640px) 45vw, 90vw"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <CardIllustration slug={articleSlug} title={a.data.title} />
                  )}
                </div>
                <div class="ed-card-kicker">{pillarLabel(a.data.pillar)}</div>
                <div class="ed-card-title">{a.data.title}</div>
                {a.data.dek && <div class="ed-card-dek">{a.data.dek}</div>}
                <div class="ed-card-byline">
                  By {a.data.byline ?? a.data.author}
                  {readingMin > 0 && (
                    <>
                      <span style="color: var(--sand); margin: 0 0.5em;">·</span>
                      {readingMin} min
                    </>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ── 4. Subscribe tiers (visual, no functional flow in Phase 1) ─ -->
  <section style="background: var(--navy); color: var(--on-dark-1); padding: 96px 0;">
    <div class="mag-container">
      <div class="subscribe-grid">
        <div>
          <div
            style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand-light); margin-bottom: 24px;"
          >
            <span style="color: var(--rust-light);">—</span>&nbsp;&nbsp;Subscribe
          </div>
          <h2
            style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); color: #fff; line-height: 1.1; letter-spacing: -0.02em; font-weight: 700; margin-bottom: 24px;"
          >
            Four issues a year, and the whole archive, for ten dollars a month.
          </h2>
          <p
            style="font-family: var(--font-body); font-size: 17px; line-height: 1.65; color: var(--on-dark-3); max-width: 420px; margin-bottom: 28px;"
          >
            The Lookout publishes quarterly. Read online, by mail, or
            one issue at a time. Cancel anytime — no password, no
            newsletter, no pressure.
          </p>
          <a href="/subscribe" class="btn-primary">See the tiers <span class="arrow">→</span></a>
        </div>

        <div class="tier-grid">
          <div class="tier-col">
            <div
              style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--sand); margin-bottom: 12px;"
            >
              Free
            </div>
            <div
              style="font-family: var(--font-display); font-size: 32px; color: #fff; letter-spacing: -0.02em; font-weight: 600; margin-bottom: 4px;"
            >
              $0
            </div>
            <div
              style="font-family: var(--font-body); font-size: 13px; color: var(--on-dark-3); line-height: 1.4;"
            >
              For readers new to The Lookout.
            </div>
          </div>
          <div class="tier-col">
            <div
              style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--rust-light); margin-bottom: 12px;"
            >
              Digital
            </div>
            <div
              style="font-family: var(--font-display); font-size: 32px; color: #fff; letter-spacing: -0.02em; font-weight: 600; margin-bottom: 4px;"
            >
              $10<span
                style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; color: var(--sand); margin-left: 4px; font-weight: 400;"
              > / month</span>
            </div>
            <div
              style="font-family: var(--font-body); font-size: 13px; color: var(--on-dark-3); line-height: 1.4;"
            >
              Everything we publish online.
            </div>
          </div>
          <div class="tier-col tier-col--last">
            <div
              style="font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase; color: var(--sand); margin-bottom: 12px;"
            >
              Print + Digital
            </div>
            <div
              style="font-family: var(--font-display); font-size: 32px; color: #fff; letter-spacing: -0.02em; font-weight: 600; margin-bottom: 4px;"
            >
              $75<span
                style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; color: var(--sand); margin-left: 4px; font-weight: 400;"
              > / quarter</span>
            </div>
            <div
              style="font-family: var(--font-body); font-size: 13px; color: var(--on-dark-3); line-height: 1.4;"
            >
              Four issues by mail. Everything else online.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 5. Archive strip ─────────────────────────────────────────── -->
  <section style="padding: 96px 0 48px;">
    <div class="mag-container">
      <div
        style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 40px; border-bottom: 1px solid var(--sand); padding-bottom: 20px; gap: 24px; flex-wrap: wrap;"
      >
        <div>
          <div class="meta-dotted" style="margin-bottom: 8px;">The Archive</div>
          <h2
            style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.8rem); letter-spacing: -0.02em; font-weight: 700;"
          >
            Every issue, from the first forward.
          </h2>
        </div>
        <a href="/archive" class="btn-link">
          See the full archive
          <svg width="12" height="12" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M4 10h12M11 5l5 5-5 5" />
          </svg>
        </a>
      </div>

      <div class="archive-grid">
        {archiveStripCards.map(({ issue: i, status, variant }) => {
          const iSlug = i.id.replace(/\.md$/, '');
          const iSeason = i.data.season.charAt(0).toUpperCase() + i.data.season.slice(1);
          const iNumber = String(i.data.issue_number).padStart(2, '0');
          const statusLabel =
            variant === 'current' ? 'Current' :
            variant === 'next'    ? 'Next'    :
            variant === 'later'   ? 'Later'   : 'Past';
          const isFuture = status === 'future';
          const shipLabel = formatShipLabel(i.data.ship_date, isFuture);
          return (
            <a
              href={`/issues/${iSlug}`}
              class:list={[
                'archive-card',
                `archive-card--${status}`,
                `archive-card--variant-${variant}`,
                `archive-card--season-${i.data.season}`,
              ]}
            >
              <div class="issue-cover issue-cover-small">
                <span
                  class:list={[
                    'archive-status-tag',
                    `archive-status-tag--${variant}`,
                    `archive-status-tag--season-${i.data.season}`,
                  ]}
                >
                  {statusLabel}
                </span>
                {i.data.cover_image ? (
                  <CoverImage
                    src={i.data.cover_image}
                    alt={i.data.cover_image_alt ?? `${i.data.title} cover`}
                    widths={[240, 360, 480]}
                    sizes="(min-width: 1200px) 260px, (min-width: 640px) 22vw, 40vw"
                    loading="lazy"
                  />
                ) : (
                  <svg viewBox="0 0 300 400" role="img" aria-label={`${i.data.title} cover`}>
                    <rect width="300" height="400" fill="#FDFAF5" />
                    <text x="150" y="80" text-anchor="middle" font-family="'DM Mono', monospace" font-size="8" letter-spacing="3" fill="#7A6F5F">ABOVE THE HOOK</text>
                    <text x="150" y="180" text-anchor="middle" font-family="'Playfair Display', serif" font-size="34" font-weight="700" fill="#1A1208">The Local</text>
                    <text x="150" y="220" text-anchor="middle" font-family="'Playfair Display', serif" font-size="34" font-style="italic" fill="#8B3A2A">Lookout</text>
                    <text x="150" y="360" text-anchor="middle" font-family="'Playfair Display', serif" font-size="14" font-style="italic" fill="#3D3020">{i.data.theme ?? '—'}</text>
                  </svg>
                )}
              </div>
              <div class="archive-meta">
                No. {iNumber}<span style="margin: 0 0.5em; color: var(--sand);">·</span>{iSeason} {i.data.year}
              </div>
              <div class="archive-theme">{i.data.theme ?? '—'}</div>
              {shipLabel && (
                <div class:list={['archive-ship', isFuture ? 'archive-ship--future' : 'archive-ship--past']}>
                  {shipLabel}
                </div>
              )}
            </a>
          );
        })}

        {/* Pad remaining slots with placeholders — typically a no-op
            once all four seasonal issues exist for the current year. */}
        {Array.from({ length: Math.max(0, ARCHIVE_STRIP_SLOTS - archiveStripCards.length) }).map(() => (
          <div class="archive-card archive-card--placeholder" style="pointer-events: none;">
            <div class="issue-cover issue-cover-small" style="opacity: 0.24; filter: grayscale(0.8);">
              <svg viewBox="0 0 300 400" role="img" aria-label="Future issue">
                <rect width="300" height="400" fill="#EDE7D9" />
                <text x="150" y="210" text-anchor="middle" font-family="'Playfair Display', serif" font-size="60" fill="#C9B99A">—</text>
              </svg>
            </div>
            <div class="archive-meta">Future issue</div>
            <div class="archive-theme">—</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 6. Coming Next ──────────────────────────────────────────── -->
  {nextData && (
    <section style="padding: 72px 0 96px;">
      <div class="mag-container">
        <a href={nextSlug ? `/next` : '#'} class="next-card-link">
          <div class="next-card">
            <div
              style="position: absolute; top: 0; left: 0; height: 2px; width: 80px; background: var(--rust);"
            ></div>
            <div class="issue-cover" style="max-width: 280px;">
              {nextData.cover_image ? (
                <CoverImage
                  src={nextData.cover_image}
                  alt={nextData.cover_image_alt ?? `${nextData.title} cover`}
                  widths={[240, 360, 480]}
                  sizes="(min-width: 900px) 280px, 60vw"
                  loading="lazy"
                />
              ) : (
                <svg viewBox="0 0 280 400" role="img" aria-label={`${nextData.title} cover`}>
                  <rect width="280" height="400" fill="#FDFAF5" />
                  <circle cx="210" cy="150" r="30" fill="#C4583E" opacity="0.4" />
                  <path d="M0 260 Q 70 240 140 248 Q 210 256 280 242 L 280 320 L 0 320 Z" fill="#2A4470" opacity="0.18" />
                  <text x="140" y="72" text-anchor="middle" font-family="'DM Mono', monospace" font-size="8" letter-spacing="3" fill="#7A6F5F">ABOVE THE HOOK</text>
                  <text x="140" y="184" text-anchor="middle" font-family="'Playfair Display', serif" font-size="32" font-weight="700" fill="#1A1208">The Local</text>
                  <text x="140" y="222" text-anchor="middle" font-family="'Playfair Display', serif" font-size="32" font-style="italic" fill="#8B3A2A">Lookout</text>
                  <text x="140" y="360" text-anchor="middle" font-family="'Playfair Display', serif" font-size="15" font-style="italic" fill="#3D3020">{nextData.theme ?? '—'}</text>
                  <text x="140" y="384" text-anchor="middle" font-family="'DM Mono', monospace" font-size="7" letter-spacing="3" fill="#7A6F5F">NO. {nextNumber} · {nextSeasonLabel.toUpperCase()} {nextData.year}</text>
                </svg>
              )}
            </div>
            <div>
              <div class="meta-dotted" style="margin-bottom: 14px;">
                Coming next<span class="dot">·</span>Issue No. {nextNumber}<span class="dot">·</span>
                <span class="rust">{nextSeasonLabel} {nextData.year}</span>
              </div>
              <h3
                style="font-family: var(--font-display); font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 700; letter-spacing: -0.02em; color: var(--navy); margin-bottom: 20px; line-height: 1.1;"
              >
                {nextData.theme ?? nextData.title}.
              </h3>
              {nextData.tagline && (
                <p
                  style="font-family: var(--font-body); font-size: 16px; line-height: 1.65; color: var(--ink-soft); margin-bottom: 24px; max-width: 520px;"
                >
                  {nextData.tagline}
                </p>
              )}
              <div
                style="display: flex; align-items: center; gap: 18px; flex-wrap: wrap;"
              >
                <div
                  style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); display: flex; align-items: center; gap: 8px;"
                >
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <path d="M4 7V5a4 4 0 0 1 8 0v2h1v8H3V7h1zm2 0h4V5a2 2 0 1 0-4 0v2z" />
                  </svg>
                  Subscriber preview
                </div>
                <span class="btn-dark">
                  See the preview <span class="arrow">→</span>
                </span>
              </div>
              <div
                style="margin-top: 24px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand);"
              >
                Publishing {nextPublishLabel}
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}
</BaseLayout>

<style>
