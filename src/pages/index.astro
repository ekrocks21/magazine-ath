  }
  .archive-card--current .archive-meta { color: var(--ink); }
  .archive-card--current .archive-theme { font-weight: 600; }

  .archive-card--future .issue-cover-small { opacity: 0.85; }
  .archive-card--future .archive-theme { font-style: italic; color: var(--ink-soft); }
  /* "Later" is further out than "Next" — push it back visually too. */
