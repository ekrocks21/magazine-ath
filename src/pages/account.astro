---
/**
 * /account — first-party account management.
 *
 * Static Astro shell. All state comes from the Worker's
 * /api/account/status endpoint on load. Cancel / resume / change-tier
 * actions POST to their respective endpoints, then re-fetch status.
 *
 * This page does not gate on auth at render time — the client-side
 * script handles the "not signed in" state and prompts the user to
 * sign in via magic link.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Your account"
  description="Manage your subscription to The Local Lookout."
  ogImage="/og/default.png"
>
  <section class="account-section">
    <div class="account-container">

      <!-- State: loading (shown until /api/account/status resolves) -->
      <div data-account-state="loading">
        <p class="account-loading">Loading your account…</p>
      </div>

      <!-- State: not signed in -->
      <div data-account-state="anon" hidden>
        <div class="kicker">Sign in</div>
        <h1 class="account-title">You're not signed in.</h1>
        <p class="account-lead">
          To manage your subscription, sign in with a magic link sent
          to your email.
        </p>
        <div class="account-actions">
          <a href="/signin" class="btn-primary">Sign in</a>
          <a href="/subscribe" class="btn-ghost">See tiers</a>
        </div>
      </div>

      <!-- State: signed in -->
      <div data-account-state="signed-in" hidden>
        <div class="kicker">Your account</div>
        <h1 class="account-title">Signed in.</h1>
        <div class="account-email" data-field="email"></div>

        <!-- Banner: cancellation scheduled -->
        <div class="account-banner account-banner--cancelling" data-when="cancelling" hidden>
          <strong>Your subscription is set to cancel.</strong>
          <span data-field="cancel-on"></span>
          <button type="button" class="btn-inline" data-action="resume">Resume subscription</button>
        </div>

        <!-- Current plan card -->
        <div class="account-card" data-when="has-subscription" hidden>
          <div class="card-head">
            <div class="card-kicker">Current plan</div>
            <span class="tier-badge" data-field="tier-badge"></span>
          </div>
          <div class="card-row">
            <span class="card-label">Price</span>
            <span class="card-value" data-field="price"></span>
          </div>
          <div class="card-row">
            <span class="card-label" data-field="renewal-label">Next renewal</span>
            <span class="card-value" data-field="renewal-date"></span>
          </div>
          <div class="card-row" data-when="has-card" hidden>
            <span class="card-label">Payment</span>
            <span class="card-value" data-field="card"></span>
          </div>
        </div>

        <!-- No active subscription -->
        <div class="account-empty" data-when="no-subscription" hidden>
          <p>You're signed in, but there's no active subscription on this email.</p>
          <a href="/subscribe" class="btn-primary">Pick a tier</a>
        </div>

        <!-- Change plan -->
        <div class="account-section-block" data-when="has-subscription" hidden>
          <h2 class="section-heading">Change plan</h2>
          <p class="section-lead">
            Switch between tiers at any time. Stripe prorates the
            charge automatically — you won't lose or double-pay.
          </p>
          <div class="account-plan-options">
            <button
              type="button"
              class="plan-option"
              data-action="change-tier"
              data-tier="digital"
            >
              <span class="plan-option-name">Digital</span>
              <span class="plan-option-price">$10 / month</span>
              <span class="plan-option-current" data-when-tier="digital">Current plan</span>
              <span class="plan-option-cta" data-when-not-tier="digital">Switch →</span>
            </button>
            <button
              type="button"
              class="plan-option"
              data-action="change-tier"
              data-tier="print"
            >
              <span class="plan-option-name">Print + Digital</span>
              <span class="plan-option-price">$75 / quarter</span>
              <span class="plan-option-current" data-when-tier="print">Current plan</span>
              <span class="plan-option-cta" data-when-not-tier="print">Switch →</span>
            </button>
          </div>

          <!-- Inline tier-change confirmation -->
          <div class="account-confirm" data-confirm="change-tier" hidden>
            <p class="confirm-body">
              Switch to <strong data-field="confirm-tier-label"></strong>
              <span data-field="confirm-tier-price"></span>?
              Stripe will prorate. Your next bill runs on your current
              cycle end date.
            </p>
            <div class="confirm-actions">
              <button type="button" class="btn-primary" data-action="change-tier-confirm">Yes, switch</button>
              <button type="button" class="btn-ghost" data-action="dismiss-confirm">Cancel</button>
            </div>
          </div>
        </div>

        <!-- Payment method update -->
        <div class="account-section-block" data-when="has-subscription" hidden>
          <h2 class="section-heading">Payment method</h2>
          <p class="section-lead">
            To keep your card details off our servers, the update form
            lives with Stripe. You'll come right back here when done.
          </p>
          <a href="/api/account/payment-portal" class="btn-primary">Update card on file</a>
        </div>

        <!-- Banner: on Print but no shipping address yet -->
        <div class="account-banner account-banner--warning" data-when="print-needs-shipping" hidden>
          <strong>Add a shipping address so we can mail your next issue.</strong>
          <button type="button" class="btn-inline" data-action="edit-shipping">Add address</button>
        </div>

        <!-- Shipping address (print subscribers and anyone with a Stripe customer) -->
        <div class="account-section-block" data-when="show-shipping" hidden>
          <h2 class="section-heading" data-field="shipping-heading">Shipping address</h2>
          <p class="section-lead" data-field="shipping-lead">
            Where your printed issues arrive. This is what we use for
            the next shipment, so please keep it current if you move.
          </p>

          <!-- Display mode -->
          <div class="shipping-display" data-shipping-mode="display" hidden>
            <div class="shipping-card">
              <div class="shipping-name" data-field="ship-name"></div>
              <div class="shipping-lines" data-field="ship-lines"></div>
              <div class="shipping-phone" data-field="ship-phone"></div>
            </div>
            <button type="button" class="btn-ghost" data-action="edit-shipping">Edit address</button>
          </div>

          <!-- Empty state -->
          <div class="shipping-empty" data-shipping-mode="empty" hidden>
            <p>We don't have a shipping address on file yet.</p>
            <button type="button" class="btn-primary" data-action="edit-shipping">Add shipping address</button>
          </div>

          <!-- Edit mode: Stripe Address Element (autocomplete + validation) -->
          <form class="shipping-form" data-shipping-mode="edit" hidden>
            <div id="stripe-address-mount" class="stripe-mount">
              <p class="stripe-loading">Loading address form…</p>
            </div>
            <div class="shipping-actions">
              <button type="submit" class="btn-primary" data-field="shipping-save-btn">Save address</button>
              <button type="button" class="btn-ghost" data-action="cancel-edit-shipping">Cancel</button>
            </div>
          </form>
        </div>

        <!-- Issue purchases (if any) -->
        <div class="account-section-block" data-when="has-issue-entitlements" hidden>
          <h2 class="section-heading">Single-issue purchases</h2>
          <ul class="account-issue-list" data-field="issue-entitlements"></ul>
        </div>

        <!-- Cancel -->
        <div class="account-section-block account-danger" data-when="can-cancel" hidden>
          <h2 class="section-heading">Cancel subscription</h2>
          <p class="section-lead">
            Cancel anytime. You'll keep access until the end of your
            current billing period, then we stop billing.
          </p>
          <button type="button" class="btn-ghost btn-danger" data-action="cancel">Cancel subscription</button>

          <div class="account-confirm" data-confirm="cancel" hidden>
            <p class="confirm-body">
              Cancel your subscription? You'll keep reading until
              <strong data-field="confirm-cancel-date"></strong>. No
              further charges after that.
            </p>
            <div class="confirm-actions">
              <button type="button" class="btn-primary btn-danger" data-action="cancel-confirm">Yes, cancel</button>
              <button type="button" class="btn-ghost" data-action="dismiss-confirm">Keep subscription</button>
            </div>
          </div>
        </div>

        <!-- Sign out (always visible when signed in) -->
        <div class="account-section-block">
          <h2 class="section-heading">Sign out</h2>
          <form method="POST" action="/api/logout">
            <button type="submit" class="btn-ghost">Sign out of this device</button>
          </form>
        </div>

      </div>

      <!-- Error banner (any state) -->
      <div class="account-error" data-account-error hidden>
        <strong>Something went wrong.</strong>
        <span data-field="error-message"></span>
        <button type="button" class="btn-inline" data-action="dismiss-error">Dismiss</button>
      </div>

    </div>
  </section>

  <script is:inline>
    (function () {
      var TIER_LABEL = { digital: 'Digital', print: 'Print + Digital' };
      var TIER_PRICE = {
        digital: '$10 / month',
        print:   '$75 / quarter',
      };
      // Publishable Stripe key — safe to expose in client JS. This is
      // the same key bound to the Worker as STRIPE_PUBLISHABLE_KEY.
      var STRIPE_PK = 'pk_live_51Ln2ElKglwHHJWzMZCsB03rbZfvHCCRXNB1CSRw8S3cr5C02voSnjA5r7V25AYFLAhQ69FpiUoTOudERirSu0nw6009AoOOuFt';

      var root = document.querySelector('.account-container');
      if (!root) return;

      var pendingTierChange = null; // tier string, set while we gate on shipping
      var shippingGateReason = null; // 'tier-change' when opened as a gate
      var latestShipping = null;     // last shipping object from /status
      var stripeAddressElement = null;
      var stripePromise = null;
      var addressElementReady = false;

      refresh();

      // ── Event delegation ────────────────────────────────────────
      root.addEventListener('click', function (ev) {
        var t = ev.target;
        while (t && t !== root && !t.getAttribute) t = t.parentNode;
        if (!t || t === root) return;

        var action = t.getAttribute('data-action');
        if (!action) return;

        if (action === 'change-tier') {
          var tier = t.getAttribute('data-tier');
          if (!tier) return;
          // Skip if this is the current tier (button is a no-op).
          if (root.getAttribute('data-current-tier') === tier) return;
          pendingTierChange = tier;
          // Gate Print on having a shipping address. If missing, open
          // the shipping form first; once saved we'll resume with the
          // tier-change confirm.
          if (tier === 'print' && !hasShippingOnFile()) {
            shippingGateReason = 'tier-change';
            openShippingEdit();
            return;
          }
          showTierConfirm(tier);
        } else if (action === 'change-tier-confirm') {
          if (!pendingTierChange) return;
          doChangeTier(pendingTierChange);
        } else if (action === 'cancel') {
          var d = root.getAttribute('data-period-end-label') || 'your current period end';
          showConfirm('cancel', { 'confirm-cancel-date': d });
        } else if (action === 'cancel-confirm') {
          doCancel();
        } else if (action === 'resume') {
          doResume();
        } else if (action === 'dismiss-confirm') {
          hideConfirms();
          pendingTierChange = null;
        } else if (action === 'dismiss-error') {
          hide('[data-account-error]');
        } else if (action === 'edit-shipping') {
          openShippingEdit();
        } else if (action === 'cancel-edit-shipping') {
          closeShippingEdit();
        }
      });

      // Separate submit handler for the shipping form — reads from the
      // Stripe Address Element and POSTs to our Worker.
      document.addEventListener('submit', function (ev) {
        var form = ev.target;
        if (!form || !form.classList || !form.classList.contains('shipping-form')) return;
        ev.preventDefault();
        if (!stripeAddressElement) return;
        var saveBtn = form.querySelector('[data-field="shipping-save-btn"]');
        if (saveBtn) saveBtn.disabled = true;
        stripeAddressElement.getValue().then(function (res) {
          if (!res.complete) {
            showError('Please fill in the required address fields.');
            if (saveBtn) saveBtn.disabled = false;
            return;
          }
          var v = res.value;
          var a = v.address || {};
          var body = {
            name: v.name || '',
            line1: a.line1 || '',
            line2: a.line2 || '',
            city: a.city || '',
            state: a.state || '',
            postal_code: a.postal_code || '',
            country: a.country || 'US',
            phone: v.phone || '',
          };
          return postForm('/api/account/shipping', body).then(function () {
            // If we opened the form as a gate before a tier change,
            // resume that flow; otherwise just return to display.
            var queuedTier = shippingGateReason === 'tier-change' ? pendingTierChange : null;
            shippingGateReason = null;
            closeShippingEdit();
            if (queuedTier) {
              // Status refresh happens inside closeShippingEdit already
              // — wait a tick so hasShippingOnFile() sees the new data.
              setTimeout(function () { showTierConfirm(queuedTier); }, 250);
            }
          });
        }).catch(function (err) {
          showError('Address save failed: ' + (err && err.message ? err.message : err));
        }).finally(function () {
          if (saveBtn) saveBtn.disabled = false;
        });
      });

      // ── API calls ───────────────────────────────────────────────
      function refresh() {
        show('[data-account-state="loading"]');
        hide('[data-account-state="anon"]');
        hide('[data-account-state="signed-in"]');

        fetch('/api/account/status', { credentials: 'same-origin', cache: 'no-store' })
          .then(function (r) { return r.ok ? r.json() : Promise.reject(new Error('HTTP ' + r.status)); })
          .then(render)
          .catch(function (err) {
            hide('[data-account-state="loading"]');
            showError(err.message || 'Failed to load account');
            show('[data-account-state="anon"]');
          });
      }

      function doCancel() {
        postJson('/api/account/cancel', {})
          .then(function () { hideConfirms(); refresh(); })
          .catch(function (err) { showError('Cancel failed: ' + err.message); });
      }

      function doResume() {
        postJson('/api/account/resume', {})
          .then(refresh)
          .catch(function (err) { showError('Resume failed: ' + err.message); });
      }

      function doChangeTier(tier) {
        postForm('/api/account/change-tier', { tier: tier })
          .then(function () { hideConfirms(); pendingTierChange = null; refresh(); })
          .catch(function (err) {
            // Worker backstop: if shipping was missing on the Stripe
            // customer, open the shipping form as a gate and try again
            // after save. Normally the client-side check catches this
            // first, but we defend in depth.
            if (err && err.message && err.message.indexOf('shipping_required') !== -1) {
              hideConfirms();
              shippingGateReason = 'tier-change';
              pendingTierChange = tier;
              openShippingEdit();
              return;
            }
            showError('Plan change failed: ' + err.message);
          });
      }

      function postJson(url, body) {
        return fetch(url, {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        }).then(handleResponse);
      }

      function postForm(url, body) {
        var params = new URLSearchParams();
        for (var k in body) params.append(k, body[k]);
        return fetch(url, {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString(),
        }).then(handleResponse);
      }

      function handleResponse(r) {
        if (r.ok) return r.json();
        return r.json().then(
          function (j) { throw new Error(j.error || ('HTTP ' + r.status)); },
          function () { throw new Error('HTTP ' + r.status); },
        );
      }

      // ── Render ──────────────────────────────────────────────────
      function render(data) {
        hide('[data-account-state="loading"]');
        hide('[data-account-error]');

        if (!data.signedIn) {
          show('[data-account-state="anon"]');
          return;
        }
        show('[data-account-state="signed-in"]');

        // Email
        setText('[data-field="email"]', data.email);

        // Subscription state blocks
        var hasSub = data.tier === 'digital' || data.tier === 'print';
        toggle('[data-when="has-subscription"]', hasSub);
        toggle('[data-when="no-subscription"]', !hasSub);

        if (hasSub) {
          setText('[data-field="tier-badge"]', TIER_LABEL[data.tier] || data.tier);
          setText('[data-field="price"]', formatPrice(data));
          var periodEndLabel = formatDate(data.current_period_end);
          root.setAttribute('data-current-tier', data.tier);
          root.setAttribute('data-period-end-label', periodEndLabel);

          // Cancelling vs active
          var cancelling = data.status === 'cancelling';
          toggle('[data-when="cancelling"]', cancelling);
          toggle('[data-when="can-cancel"]', !cancelling);
          if (cancelling) {
            setText('[data-field="cancel-on"]', ' Access ends on ' + periodEndLabel + '.');
            var renewalLabel = root.querySelector('[data-field="renewal-label"]');
            if (renewalLabel) renewalLabel.textContent = 'Access ends';
          }
          setText('[data-field="renewal-date"]', periodEndLabel);

          // Card
          if (data.card) {
            toggle('[data-when="has-card"]', true);
            setText('[data-field="card"]', capitalize(data.card.brand) + ' ending ' + data.card.last4);
          } else {
            toggle('[data-when="has-card"]', false);
          }

          // Mark which plan option is current
          var options = root.querySelectorAll('[data-action="change-tier"]');
          for (var i = 0; i < options.length; i++) {
            var opt = options[i];
            var optTier = opt.getAttribute('data-tier');
            var isCurrent = optTier === data.tier;
            opt.classList.toggle('plan-option--current', isCurrent);
            opt.setAttribute('aria-current', isCurrent ? 'true' : 'false');
            var currentLabel = opt.querySelector('[data-when-tier="' + optTier + '"]');
            var switchLabel = opt.querySelector('[data-when-not-tier="' + optTier + '"]');
            if (currentLabel) currentLabel.hidden = !isCurrent;
            if (switchLabel) switchLabel.hidden = isCurrent;
          }
        }

        // Issue entitlements list
        var issues = data.issue_entitlements || [];
        toggle('[data-when="has-issue-entitlements"]', issues.length > 0);
        if (issues.length > 0) {
          var ul = root.querySelector('[data-field="issue-entitlements"]');
          if (ul) {
            ul.innerHTML = '';
            for (var j = 0; j < issues.length; j++) {
              var li = document.createElement('li');
              li.textContent = prettyIssueSlug(issues[j]);
              ul.appendChild(li);
            }
          }
        }

        // Shipping section. Show for print subscribers, or for anyone
        // who already has a shipping address on file (e.g. single-issue
        // buyer who may want to update it before the next order).
        var showShipping = data.tier === 'print' || !!data.shipping;
        toggle('[data-when="show-shipping"]', showShipping);
        latestShipping = data.shipping || null;

        // Warning banner: print subscriber without shipping address.
        var needsAddress = data.tier === 'print' && !hasShippingOnFile();
        toggle('[data-when="print-needs-shipping"]', needsAddress);

        if (showShipping) {
          var mode = hasShippingOnFile() ? 'display' : 'empty';
          toggle('[data-shipping-mode="display"]', mode === 'display');
          toggle('[data-shipping-mode="empty"]', mode === 'empty');
          toggle('[data-shipping-mode="edit"]', false);
          if (hasShippingOnFile()) {
            var ship = latestShipping;
            setText('[data-field="ship-name"]', ship.name || '—');
            var addrHtml =
              escapeHtml(ship.line1) +
              (ship.line2 ? '<br>' + escapeHtml(ship.line2) : '') +
              '<br>' +
              escapeHtml((ship.city || '') + ', ' + (ship.state || '') + ' ' + (ship.postal_code || '')) +
              (ship.country && ship.country !== 'US' ? '<br>' + escapeHtml(ship.country) : '');
            var lines = root.querySelector('[data-field="ship-lines"]');
            if (lines) lines.innerHTML = addrHtml;
            setText('[data-field="ship-phone"]', ship.phone || '');
          }
        }

        // If a shipping gate is open, re-apply the gate context copy.
        applyShippingGateCopy();
      }

      function hasShippingOnFile() {
        var s = latestShipping;
        return !!(s && s.line1 && s.city && s.state && s.postal_code);
      }

      function showTierConfirm(tier) {
        showConfirm('change-tier', {
          'confirm-tier-label': TIER_LABEL[tier] || tier,
          'confirm-tier-price': ' (' + (TIER_PRICE[tier] || '') + ')',
        });
      }

      function openShippingEdit() {
        toggle('[data-shipping-mode="display"]', false);
        toggle('[data-shipping-mode="empty"]', false);
        toggle('[data-shipping-mode="edit"]', true);
        applyShippingGateCopy();
        mountStripeAddressElement().catch(function (err) {
          showError('Address form failed to load: ' + (err && err.message ? err.message : err));
        });
      }

      function closeShippingEdit() {
        toggle('[data-shipping-mode="edit"]', false);
        // Reset any gate state. The tier-change retry path clears this
        // itself before calling in, so this only fires for plain cancels.
        if (shippingGateReason === 'tier-change') {
          pendingTierChange = null;
        }
        shippingGateReason = null;
        applyShippingGateCopy();
        refresh();
      }

      function applyShippingGateCopy() {
        var h = root.querySelector('[data-field="shipping-heading"]');
        var p = root.querySelector('[data-field="shipping-lead"]');
        if (!h || !p) return;
        if (shippingGateReason === 'tier-change') {
          h.textContent = 'Add a shipping address';
          p.textContent =
            'Print subscribers need a mailing address. Save it below, ' +
            'then we\'ll switch your plan.';
        } else {
          h.textContent = 'Shipping address';
          p.textContent =
            'Where your printed issues arrive. This is what we use for ' +
            'the next shipment, so please keep it current if you move.';
        }
      }

      // ── Stripe Address Element ──────────────────────────────────
      function loadStripeSdk() {
        if (stripePromise) return stripePromise;
        stripePromise = new Promise(function (resolve, reject) {
          if (typeof window.Stripe === 'function') { resolve(window.Stripe); return; }
          var s = document.createElement('script');
          s.src = 'https://js.stripe.com/v3/';
          s.onload = function () { resolve(window.Stripe); };
          s.onerror = function () { reject(new Error('Stripe.js failed to load')); };
          document.head.appendChild(s);
        });
        return stripePromise;
      }

      function mountStripeAddressElement() {
        return loadStripeSdk().then(function (StripeFactory) {
          var stripe = StripeFactory(STRIPE_PK);
          var elements = stripe.elements({
            mode: 'setup',
            currency: 'usd',
            appearance: {
              theme: 'stripe',
              variables: {
                fontFamily: 'Source Serif 4, Georgia, serif',
                colorPrimary: '#A0452E',
                colorText: '#1A1208',
                colorBackground: '#F5F0E8',
                borderRadius: '0px',
                fontSizeBase: '15px',
              },
            },
          });
          var defaults = mapShippingToStripeDefaults(latestShipping);
          // Destroy any previous mount (we re-create on each open so the
          // defaults reflect the latest status).
          if (stripeAddressElement) {
            try { stripeAddressElement.destroy(); } catch (_) {}
            stripeAddressElement = null;
          }
          stripeAddressElement = elements.create('address', {
            mode: 'shipping',
            allowedCountries: ['US'],
            fields: { phone: 'always' },
            validation: { phone: { required: 'never' } },
            defaultValues: defaults,
            display: { name: 'full' },
          });
          var mount = document.getElementById('stripe-address-mount');
          if (mount) mount.innerHTML = '';
          stripeAddressElement.mount('#stripe-address-mount');
          addressElementReady = true;
        });
      }

      function mapShippingToStripeDefaults(ship) {
        if (!ship) return { address: { country: 'US' } };
        return {
          name: ship.name || '',
          phone: ship.phone || '',
          address: {
            line1: ship.line1 || '',
            line2: ship.line2 || '',
            city: ship.city || '',
            state: ship.state || '',
            postal_code: ship.postal_code || '',
            country: ship.country || 'US',
          },
        };
      }

      function escapeHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
          return c === '&' ? '&amp;'
            : c === '<' ? '&lt;'
            : c === '>' ? '&gt;'
            : c === '"' ? '&quot;'
            : '&#39;';
        });
      }

      // ── UI helpers ──────────────────────────────────────────────
      function show(sel) {
        var el = root.querySelector(sel);
        if (el) el.removeAttribute('hidden');
      }
      function hide(sel) {
        var el = root.querySelector(sel);
        if (el) el.setAttribute('hidden', '');
      }
      function toggle(sel, on) {
        var els = root.querySelectorAll(sel);
        for (var i = 0; i < els.length; i++) {
          if (on) els[i].removeAttribute('hidden');
          else    els[i].setAttribute('hidden', '');
        }
      }
      function setText(sel, text) {
        var el = root.querySelector(sel);
        if (el) el.textContent = text;
      }
      function showConfirm(name, fields) {
        hideConfirms();
        var panel = root.querySelector('[data-confirm="' + name + '"]');
        if (!panel) return;
        for (var k in fields) {
          var f = panel.querySelector('[data-field="' + k + '"]');
          if (f) f.textContent = fields[k];
        }
        panel.removeAttribute('hidden');
        panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      function hideConfirms() {
        var panels = root.querySelectorAll('[data-confirm]');
        for (var i = 0; i < panels.length; i++) panels[i].setAttribute('hidden', '');
      }
      function showError(msg) {
        var box = root.querySelector('[data-account-error]');
        if (!box) return;
        var m = box.querySelector('[data-field="error-message"]');
        if (m) m.textContent = ' ' + msg;
        box.removeAttribute('hidden');
      }

      // ── Formatting ──────────────────────────────────────────────
      function formatPrice(d) {
        if (d.amount_cents == null) return '';
        var amt = '$' + (d.amount_cents / 100).toFixed(2).replace(/\.00$/, '');
        if (d.interval) {
          var count = d.interval_count && d.interval_count !== 1 ? d.interval_count + ' ' : '';
          amt += ' / ' + count + d.interval + (d.interval_count > 1 ? 's' : '');
        }
        return amt;
      }
      function formatDate(unix) {
        if (!unix) return '';
        var d = new Date(unix * 1000);
        return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
      }
      function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : s; }
      function prettyIssueSlug(s) {
        return s.split('-').map(function (w) {
          return w.charAt(0).toUpperCase() + w.slice(1);
        }).join(' ');
      }
    })();
  </script>
</BaseLayout>

