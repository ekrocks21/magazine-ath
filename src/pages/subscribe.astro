---
/**
 * /subscribe — Tier page.
 *
 * Live commerce. Three tiers plus single-issue purchase, all posting
 * to /api/checkout (handled by the Cloudflare Worker). Sign-in form
 * posts to /api/login-request (magic link via Resend).
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Enumerate available single-issue purchases.
const allIssues = await getCollection('issues');
const singleIssueOptions = allIssues
  .filter((i) => i.data.order_print === true)
  .sort((a, b) => {
    const aDate = a.data.publish_date ? new Date(a.data.publish_date).getTime() : 0;
    const bDate = b.data.publish_date ? new Date(b.data.publish_date).getTime() : 0;
    return bDate - aDate;
  })
  .map((i) => ({
    slug: i.id.replace(/\.md$/, ''),
    title: i.data.title,
    issue_number: i.data.issue_number,
    theme: i.data.theme,
  }));
---

<BaseLayout
  title="Subscribe — The Local Lookout"
  description="Four issues a year, and the whole archive. Ten dollars a month for digital, seventy-five a quarter for print, one hundred for a single issue."
  ogImage="/og/default.png"
>
  <!-- Hero -->
  <section style="padding: 96px 0 56px;">
    <div class="mag-container-narrow" style="text-align: center;">
      <div class="meta-dotted" style="margin-bottom: 20px; justify-content: center;">
        Subscribe<span class="dot">·</span>Three tiers, one magazine
      </div>
      <h1
        style="font-family: var(--font-display); font-weight: 700; font-size: clamp(2.6rem, 5.2vw, 4rem); letter-spacing: -0.025em; color: var(--ink); line-height: 1.05; margin-bottom: 24px;"
      >
        Four issues a year, <em style="font-weight: 400; color: var(--rust);">and the whole archive.</em>
      </h1>
      <p
        style="font-family: var(--font-display); font-style: italic; font-size: 20px; line-height: 1.55; color: var(--ink-soft); max-width: 620px; margin: 0 auto;"
      >
        The Local Lookout publishes quarterly. Pick the tier that
        matches how you read — on a screen, in the mail, or once, for
        the one issue that pulled you in.
      </p>
    </div>
  </section>

  <!-- Signed-in subscriber banner (revealed by JS when /api/me
       reports an active tier). Sits above the tier cards so the
       page reads as "you're in" before they scan the grid. -->
  <section class="subscriber-banner-section" data-mag-subscriber-banner hidden>
    <div class="mag-container-narrow">
      <div class="subscriber-banner">
        <div class="subscriber-banner-copy">
          <span class="subscriber-banner-kicker">You're subscribed</span>
          <strong data-mag-current-tier-label></strong>
        </div>
        <a href="/account" class="subscriber-banner-cta">Manage your plan →</a>
      </div>
    </div>
  </section>

  <!-- Tier cards -->
  <section style="padding: 40px 0 56px;">
    <div class="mag-container">
      <div class="tier-cards">
        <!-- Free -->
        <div class="tier-card" data-mag-tier-card="free">
          <div class="tier-card-kicker" style="color: var(--muted);">Free</div>
          <div class="tier-card-price">
            $0
          </div>
          <div class="tier-card-cadence">Forever</div>
          <p class="tier-card-desc">
            For readers new to The Lookout. Editor's letters, one free
            feature per issue, and the archive of past free stories.
          </p>
          <ul class="tier-list">
            <li>Editor's letter every issue</li>
            <li>One free feature per issue</li>
            <li>Full archive of past free stories</li>
            <li>RSS feed</li>
          </ul>
          <span class="tier-cta tier-cta--disabled" data-mag-tier-cta="anon">Currently what you have</span>
          <span class="tier-cta tier-cta--disabled" data-mag-tier-cta="included" hidden>Included with your plan</span>
        </div>

        <!-- Digital (featured) -->
        <div class="tier-card tier-card--featured" data-mag-tier-card="digital">
          <div class="tier-badge">Most read</div>
          <div class="tier-card-kicker" style="color: var(--rust);">Digital</div>
          <div class="tier-card-price">
            $10<span class="tier-card-unit"> / month</span>
          </div>
          <div class="tier-card-cadence">Billed monthly</div>
          <p class="tier-card-desc">
            Everything we publish online. Subscriber-only features, the
            preview of every future issue, and every story once it
            leaves the front window.
          </p>
          <ul class="tier-list">
            <li>All features and subscriber essays</li>
            <li>Previews of future issues</li>
            <li>Audio narration of every story</li>
            <li>Cancel anytime from your account</li>
          </ul>
          <form method="POST" action="/api/checkout" class="tier-form" data-mag-tier-cta="anon">
            <input type="hidden" name="tier" value="digital" />
            <button type="submit" class="tier-cta tier-cta--live">
              Subscribe — $10 / mo
            </button>
          </form>
          <a href="/account" class="tier-cta tier-cta--current" data-mag-tier-cta="current" hidden>
            ✓ Current plan · Manage
          </a>
          <a href="/account" class="tier-cta tier-cta--switch" data-mag-tier-cta="switch" hidden>
            <span data-mag-switch-label>Switch to Digital</span> →
          </a>
        </div>

        <!-- Print + Digital -->
        <div class="tier-card" data-mag-tier-card="print">
          <div class="tier-card-kicker" style="color: var(--muted);">Print + Digital</div>
          <div class="tier-card-price">
            $75<span class="tier-card-unit"> / quarter</span>
          </div>
          <div class="tier-card-cadence">Billed quarterly</div>
          <p class="tier-card-desc">
            Four issues delivered by mail. Thick paper, real ink, wide
            margins. Includes everything in Digital, plus the printed
            edition mailed the week it ships.
          </p>
          <ul class="tier-list">
            <li>Everything in Digital</li>
            <li>Four printed issues a year</li>
            <li>Mailed from Highlands, NJ</li>
            <li>Back issues at half price ($50)</li>
          </ul>
          <form method="POST" action="/api/checkout" class="tier-form" data-mag-tier-cta="anon">
            <input type="hidden" name="tier" value="print" />
            <button type="submit" class="tier-cta tier-cta--live">
              Subscribe — $75 / quarter
            </button>
          </form>
          <a href="/account" class="tier-cta tier-cta--current" data-mag-tier-cta="current" hidden>
            ✓ Current plan · Manage
          </a>
          <a href="/account" class="tier-cta tier-cta--switch" data-mag-tier-cta="switch" hidden>
            <span data-mag-switch-label>Upgrade to Print + Digital</span> →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Single-issue row -->
  <section style="padding: 0 0 96px;">
    <div class="mag-container-narrow">
      <div class="single-issue">
        <div class="single-issue-hdr">
          <div>
            <div class="single-issue-kicker">One issue at a time</div>
            <h3 class="single-issue-title">
              Buy a single issue — <em>$100</em>
            </h3>
            <p class="single-issue-desc">
              One printed copy, plus digital access to that issue.
              For readers who want one specific issue without a
              subscription, or to gift the magazine one time.
              <span class="single-issue-sub-note">
                Print subscribers buy extras at $50 — sign in first
                and the price adjusts automatically.
              </span>
            </p>
          </div>
        </div>
        <div class="single-issue-grid">
          {singleIssueOptions.length === 0 ? (
            <p class="single-issue-empty">No issues available for single purchase yet.</p>
          ) : (
            singleIssueOptions.map((i) => (
              <form method="POST" action="/api/checkout" class="single-issue-card" data-single-issue-form>
                <input type="hidden" name="tier" value="single" />
                <input type="hidden" name="issue" value={i.slug} />
                <div class="single-issue-card-num">
                  Issue No. {String(i.issue_number ?? '').padStart(2, '0')}
                </div>
                <div class="single-issue-card-title">{i.title}</div>
                {i.theme && (
                  <div class="single-issue-card-theme">{i.theme}</div>
                )}
                <button type="submit" class="single-issue-card-cta" data-single-issue-cta>
                  Buy — <span data-single-issue-price>$100</span> →
                </button>
              </form>
            ))
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Sign-in -->
  <section id="signin" style="background: var(--navy); color: var(--on-dark-1); padding: 80px 0;">
    <div class="mag-container-narrow" style="text-align: center;">
      <div
        style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand-light); margin-bottom: 20px;"
      >
        <span style="color: var(--rust-light);">—</span>&nbsp;&nbsp;Already subscribed
      </div>
      <h2
        style="font-family: var(--font-display); font-size: clamp(1.8rem, 3.4vw, 2.4rem); color: #fff; line-height: 1.15; letter-spacing: -0.02em; font-weight: 700; margin-bottom: 20px;"
      >
        Sign in to read.
      </h2>
      <p
        style="font-family: var(--font-body); font-size: 17px; line-height: 1.65; color: var(--on-dark-3); max-width: 540px; margin: 0 auto 32px;"
      >
        Type your email and we'll send a one-click sign-in link. No
        password to forget, no newsletter to unsubscribe from.
      </p>
      <form class="signin-form" method="POST" action="/api/login-request">
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="signin-input"
          aria-label="Email address"
        />
        <button type="submit" class="signin-button">
          Send sign-in link <span class="arrow">→</span>
        </button>
      </form>
      <p
        style="margin-top: 16px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--sand);"
      >
        The link expires in 15 minutes
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding: 96px 0;">
    <div class="mag-container-narrow">
      <div class="meta-dotted" style="margin-bottom: 16px; justify-content: center;">
        Questions we get
      </div>
      <h2
        style="font-family: var(--font-display); font-size: clamp(1.8rem, 3.4vw, 2.4rem); font-weight: 700; letter-spacing: -0.02em; text-align: center; margin-bottom: 48px;"
      >
        A few things to know.
      </h2>

      <div class="faq-list">
        <div class="faq-item">
          <h3 class="faq-q">Can I cancel?</h3>
          <p class="faq-a">
            Anytime, from your account page. Digital cancels end at the
            close of the current billing month; print cancels end at
            the close of the current quarter. You keep access through
            whatever you already paid for.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-q">What happens to the free version?</h3>
          <p class="faq-a">
            Nothing changes. The editor's letter, one free feature per
            issue, and the archive of past free stories stay free. The
            Digital tier is additive — subscriber features, previews,
            and audio — not a paywall dropping in front of what you
            already read.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-q">Does the print subscription include digital?</h3>
          <p class="faq-a">
            Yes. Print is a superset of Digital. You get the mailed
            magazine and everything online, signed in with the same
            email.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-q">How does the single-issue purchase work?</h3>
          <p class="faq-a">
            Pick an issue, pay $100 once, give us a shipping address.
            We mail the printed copy from Highlands, and the digital
            version of that issue unlocks for you right away.
          </p>
        </div>

        <div class="faq-item">
          <h3 class="faq-q">Who is behind the magazine?</h3>
          <p class="faq-a">
            The Local Lookout is the quarterly print publication of
            Above the Hook, a place-based coastal storytelling brand
            founded in 2025 by Eric Kane and Mary McKiever, based in
            Highlands, New Jersey.
          </p>
        </div>
      </div>

      <div style="text-align: center; margin-top: 56px;">
        <p
          style="font-family: var(--font-body); font-size: 16px; line-height: 1.65; color: var(--ink-soft);"
        >
          Still have a question? Write us at
          <a
            href="mailto:hello@abovethehook.com"
            style="color: var(--rust); text-decoration: underline; text-underline-offset: 3px;"
            >hello@abovethehook.com</a
          >.
        </p>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      /* Reshape the tier grid to reflect the signed-in reader's
         current plan. Anonymous / no-tier readers see the default
         Subscribe CTAs. */
      var TIER_LABELS = {
        digital: 'Digital — $10 / mo',
        print:   'Print + Digital — $75 / quarter',
      };
      // Only digital and print are switchable. "free" is always
      // included for subscribers, never a separate purchase.
      var TIER_RANK = { free: 0, digital: 1, print: 2 };

      fetch('/api/me', { credentials: 'same-origin', cache: 'no-store' })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (!data || !data.signedIn) return;
          var ents = data.entitlements || [];
          var activeTier = null;
          for (var i = 0; i < ents.length; i++) {
            if (ents[i].tier === 'print') { activeTier = 'print'; break; }
            if (ents[i].tier === 'digital') activeTier = 'digital';
          }
          if (!activeTier) return;

          // Reveal the top banner
          var banner = document.querySelector('[data-mag-subscriber-banner]');
          if (banner) {
            banner.removeAttribute('hidden');
            var label = banner.querySelector('[data-mag-current-tier-label]');
            if (label) label.textContent = TIER_LABELS[activeTier] || activeTier;
          }

          // Update each tier card's CTA
          var cards = document.querySelectorAll('[data-mag-tier-card]');
          for (var c = 0; c < cards.length; c++) {
            var card = cards[c];
            var cardTier = card.getAttribute('data-mag-tier-card');

            // Free card: show "Included" label for any paying tier
            if (cardTier === 'free') {
              setCtaState(card, 'included');
              continue;
            }
            // Current plan
            if (cardTier === activeTier) {
              setCtaState(card, 'current');
              card.classList.add('tier-card--current');
              continue;
            }
            // Switch: either upgrade (to higher rank) or downgrade (to lower)
            var fromRank = TIER_RANK[activeTier];
            var toRank = TIER_RANK[cardTier];
            var isUpgrade = toRank > fromRank;
            var switchLabel = card.querySelector('[data-mag-switch-label]');
            if (switchLabel) {
              switchLabel.textContent = isUpgrade
                ? 'Upgrade to ' + labelFor(cardTier)
                : 'Downgrade to ' + labelFor(cardTier);
            }
            setCtaState(card, 'switch');
          }
        })
        .catch(function () { /* keep defaults on any failure */ });

      function labelFor(tier) {
        if (tier === 'print') return 'Print + Digital';
        if (tier === 'digital') return 'Digital';
        return tier;
      }

      function setCtaState(card, state) {
        var ctas = card.querySelectorAll('[data-mag-tier-cta]');
        for (var i = 0; i < ctas.length; i++) {
          if (ctas[i].getAttribute('data-mag-tier-cta') === state) {
            ctas[i].removeAttribute('hidden');
          } else {
            ctas[i].setAttribute('hidden', '');
          }
        }
      }
    })();
  </script>
</BaseLayout>

<style>
  .tier-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  .tier-card {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--sand);
    padding: 40px 32px 32px;
    display: flex;
    flex-direction: column;
  }

  .tier-card--featured {
    border: 2px solid var(--rust);
    background: var(--cream-dark, var(--paper));
    transform: translateY(-12px);
  }

  .tier-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--rust);
    color: #fff;
    padding: 6px 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .tier-card-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .tier-card-price {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 4px;
  }

  .tier-card-unit {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.12em;
    color: var(--muted);
    font-weight: 400;
    margin-left: 6px;
  }

  .tier-card-cadence {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 20px;
  }

  .tier-card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 24px;
  }

  .tier-list {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    border-top: 1px solid var(--sand);
  }
  .tier-list li {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink);
    padding: 12px 0;
    border-bottom: 1px solid var(--sand);
  }
  .tier-list li::before {
    content: '·';
    color: var(--rust);
    margin-right: 10px;
    font-weight: 700;
  }

  .tier-form {
    margin-top: auto;
  }

  .tier-cta {
    display: block;
    text-align: center;
    padding: 14px 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-top: auto;
    border: 0;
    cursor: pointer;
    width: 100%;
  }

  .tier-cta--disabled {
    background: var(--sand-light, #e8e0cd);
    color: var(--muted);
    cursor: not-allowed;
    border: 1px solid var(--sand);
  }

  .tier-cta--live {
    background: var(--rust);
    color: #fff;
    transition: background 0.15s ease-out;
  }
  .tier-cta--live:hover {
    background: var(--rust-light, #C4583E);
  }

  /* Current-plan CTA: solid navy with a checkmark, links to /account */
  .tier-cta--current {
    background: var(--navy);
    color: #fff;
    text-decoration: none;
    border: 0;
  }
  .tier-cta--current:hover {
    background: var(--navy-light, #1C4472);
  }

  /* Switch-plan CTA (upgrade/downgrade): outlined, understated */
  .tier-cta--switch {
    background: transparent;
    color: var(--rust);
    border: 1px solid var(--rust);
    text-decoration: none;
    transition: background 0.15s ease-out, color 0.15s ease-out;
  }
  .tier-cta--switch:hover {
    background: var(--rust);
    color: #fff;
  }

  /* Current-plan card gets a subtle ring so the eye lands on it */
  .tier-card--current {
    border-color: var(--navy);
    border-width: 2px;
  }

  /* Subscriber banner */
  .subscriber-banner-section {
    padding: 16px 0 0;
  }
  .subscriber-banner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    padding: 16px 22px;
    background: var(--cream-dark, #EFE6D2);
    border: 1px solid var(--sand);
  }
  .subscriber-banner-copy {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--ink);
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }
  .subscriber-banner-kicker {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rust);
  }
  .subscriber-banner-copy strong {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .subscriber-banner-cta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rust);
    text-decoration: none;
    border: 1px solid var(--rust);
    padding: 9px 14px;
    transition: background 0.15s ease-out, color 0.15s ease-out;
  }
  .subscriber-banner-cta:hover {
    background: var(--rust);
    color: #fff;
  }

  /* Single issue */
  .single-issue {
    background: var(--paper);
    border: 1px solid var(--sand);
    padding: 44px 48px;
  }
  .single-issue-hdr {
    margin-bottom: 32px;
  }
  .single-issue-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 12px;
  }
  .single-issue-title {
    font-family: var(--font-display);
    font-size: 30px;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0 0 10px;
    color: var(--ink);
  }
  .single-issue-title em {
    font-style: normal;
    color: var(--rust);
  }
  .single-issue-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 62ch;
    margin: 0;
  }
  .single-issue-sub-note {
    display: block;
    margin-top: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--rust);
  }
  .single-issue-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }
  .single-issue-card {
    border: 1px solid var(--sand);
    padding: 24px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: #fff;
  }
  .single-issue-card-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .single-issue-card-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1.2;
  }
  .single-issue-card-theme {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft);
    margin-top: 2px;
