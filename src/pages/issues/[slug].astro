---
/**
 * Issue page — /issues/[slug]
 *
 * Cover, metadata, editor's letter, table of contents.
 * Spec §4.3.
 */

import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SmallCapsLabel from '../../components/SmallCapsLabel.astro';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map((issue) => ({
    params: { slug: issue.id.replace(/\.md$/, '') },
    props: { issue },
  }));
}

interface Props {
  issue: CollectionEntry<'issues'>;
}

const { issue } = Astro.props;
const { Content: IssueBody } = await render(issue);
const slug = issue.id.replace(/\.md$/, '');
const data = issue.data;

// ── Articles in this issue ─────────────────────────────────────────────

const includeDrafts =
  import.meta.env.PUBLIC_INCLUDE_DRAFTS === 'true' ||
  import.meta.env.DEV === true;

const allArticles = await getCollection('articles', ({ data: d }) =>
  includeDrafts ? true : d.status !== 'draft',
);

const issueArticles = allArticles.filter((a) =>
  a.id.startsWith(`${slug}/`),
);

// Editor's letter resolved by configured slug, falling back to type === 'editors_letter'
const editorsLetterEntry =
  (data.editors_letter
    ? issueArticles.find(
        (a) => a.id === `${slug}/${data.editors_letter}.md` ||
               a.id.replace(/\.md$/, '') === `${slug}/${data.editors_letter}`,
      )
    : undefined) ??
  issueArticles.find((a) => a.data.type === 'editors_letter');

const tocArticles = issueArticles.filter(
  (a) => a.id !== editorsLetterEntry?.id,
);

// Render editor's letter body inline
const { Content: LetterBody } = editorsLetterEntry
  ? await render(editorsLetterEntry)
  : { Content: null };

// ── Metadata strings ──────────────────────────────────────────────────

const seasonLabel = data.season.charAt(0).toUpperCase() + data.season.slice(1);
const statusLabel = {
  planning: 'In Planning',
  in_production: 'In Production',
  published: 'Published',
  archived: 'Archived',
}[data.status];

const issueNumber = String(data.issue_number).padStart(2, '0');

const dateLabel = data.publish_date
  ? data.publish_date.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : undefined;
---

<BaseLayout
  title={`${data.title}: ${data.theme ?? 'Current Issue'}`}
  description={`The ${data.title} issue of The Local Lookout${data.theme ? ` — ${data.theme}.` : '.'}`}
  ogImage={data.cover_image}
>
  <!-- Cover treatment. Falls back to a stylized placeholder block when
       no cover image is uploaded yet. -->
  <section
    class="bg-[var(--color-navy)] text-[var(--color-cream)] overflow-hidden"
  >
    <div class="max-w-5xl mx-auto px-6 md:px-10 py-16 md:py-24">
      <div class="grid md:grid-cols-[auto_1fr] gap-10 md:gap-16 items-center">
        <!-- Cover art (or placeholder) -->
        <div class="w-full max-w-[280px] md:max-w-[320px] mx-auto md:mx-0">
          {
            data.cover_image ? (
              <img
                src={data.cover_image}
                alt={`${data.title} cover`}
                class="w-full h-auto shadow-2xl"
                loading="eager"
                decoding="async"
              />
            ) : (
              <div
                class="aspect-[5/7] w-full flex flex-col items-center justify-center gap-4 shadow-2xl p-8 text-center"
                style="background: linear-gradient(135deg, var(--color-navy) 0%, #243e66 100%); border: 1px solid color-mix(in srgb, var(--color-cream) 20%, transparent);"
              >
                <p
                  class="text-[0.6rem] tracking-[0.3em] uppercase text-[var(--color-cream)]/50"
                  style="font-family: var(--font-sans);"
                >
                  Issue No. {issueNumber}
                </p>
                <p
                  class="text-4xl leading-none"
                  style="font-family: var(--font-display); font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 0;"
                >
                  {data.theme ?? seasonLabel}
                </p>
                <hr class="w-16 h-[1px] border-0 bg-[var(--color-rust)]" />
                <p
                  class="text-xs tracking-[0.25em] uppercase text-[var(--color-cream)]/70"
                  style="font-family: var(--font-sans);"
                >
                  {seasonLabel} {data.year}
                </p>
                <p
                  class="mt-2 text-sm italic text-[var(--color-cream)]/55"
                  style="font-family: var(--font-body);"
                >
                  The Local Lookout
                </p>
              </div>
            )
          }
        </div>

        <!-- Issue metadata + title -->
        <div>
          <SmallCapsLabel
            tone="cream"
            items={[
              `Issue No. ${issueNumber}`,
              `${seasonLabel} ${data.year}`,
              statusLabel,
            ]}
          />

          <h1
            class="mt-6 text-5xl md:text-7xl leading-[1.05] text-[var(--color-cream)]"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 0;"
          >
            {data.theme ?? data.title}
          </h1>

          {
            data.theme && (
              <p
                class="mt-4 text-lg md:text-xl text-[var(--color-cream)]/75"
                style="font-family: var(--font-sans);"
              >
                {data.title}
              </p>
            )
          }

          {
            dateLabel && (
              <p
                class="mt-8 text-xs tracking-[0.25em] uppercase text-[var(--color-cream)]/60"
                style="font-family: var(--font-sans);"
              >
                Published {dateLabel}
              </p>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Issue body (frontmatter-level prose for the issue page) -->
  <section class="py-16 md:py-24 px-6 md:px-10">
    <div class="article-prose text-[var(--color-ink)]">
      <IssueBody />
    </div>
  </section>

  <!-- Editor's letter, inline -->
  {
    editorsLetterEntry && LetterBody && (
      <section class="bg-[var(--color-cream)] border-y border-[var(--color-rust)]/20">
        <div class="max-w-3xl mx-auto px-6 md:px-10 py-16 md:py-24">
          <SmallCapsLabel
            tone="rust"
            items={['From the Editor', editorsLetterEntry.data.author]}
          />
          <h2
            class="mt-5 text-4xl md:text-5xl leading-tight"
            style="font-variation-settings: 'opsz' 120, 'SOFT' 50, 'WONK' 0;"
          >
            {editorsLetterEntry.data.title}
          </h2>
          <hr class="rust-rule w-20 h-[2px] mt-6 mb-10" />
          <div class="article-prose">
            <LetterBody />
          </div>
          <p class="mt-10">
            <a
              href={`/issues/${slug}/${editorsLetterEntry.id.split('/')[1].replace(/\.md$/, '')}`}
              class="text-sm tracking-[0.2em] uppercase text-[var(--color-rust)] no-underline hover:text-[var(--color-navy)]"
              style="font-family: var(--font-sans);"
            >
              Read the letter on its own page &rarr;
            </a>
          </p>
        </div>
      </section>
    )
  }

  <!-- Table of Contents -->
  {
    tocArticles.length > 0 && (
      <section class="py-16 md:py-24 px-6 md:px-10">
        <div class="max-w-4xl mx-auto">
          <SmallCapsLabel tone="rust" items={['Table of Contents']} />
          <h2
            class="mt-4 text-3xl md:text-4xl"
            style="font-variation-settings: 'opsz' 96, 'SOFT' 40, 'WONK' 0;"
          >
            In this issue
          </h2>
          <hr class="rust-rule w-20 h-[2px] mt-6 mb-10" />

          <ul class="list-none m-0 p-0 divide-y divide-[var(--color-ink)]/10">
            {tocArticles.map((a) => {
              const articleSlug = a.id.split('/')[1].replace(/\.md$/, '');
              const pillarLabel = a.data.pillar
                .split('_')
                .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
                .join(' ');
              return (
                <li class="py-6 md:py-8">
                  <a
                    href={`/issues/${slug}/${articleSlug}`}
                    class="block group no-underline"
                  >
                    <div class="flex items-baseline gap-4 mb-2">
                      <span class="tag-pill">{pillarLabel}</span>
                      {a.data.word_count && (
                        <span
                          class="text-[0.65rem] tracking-[0.2em] uppercase text-[var(--color-taupe)]"
                          style="font-family: var(--font-sans);"
                        >
                          {Math.max(1, Math.round(a.data.word_count / 220))} min
                        </span>
                      )}
                    </div>
                    <h3
                      class="text-2xl md:text-3xl leading-tight text-[var(--color-navy)] group-hover:text-[var(--color-rust)] transition-colors"
                      style="font-variation-settings: 'opsz' 96, 'SOFT' 40, 'WONK' 0;"
                    >
                      {a.data.title}
                    </h3>
                    {a.data.dek && (
                      <p
                        class="mt-3 text-base md:text-lg leading-snug text-[var(--color-taupe)] italic max-w-2xl"
                        style="font-family: var(--font-body);"
                      >
                        {a.data.dek}
                      </p>
                    )}
                    <p
                      class="mt-3 text-xs tracking-[0.2em] uppercase text-[var(--color-taupe)]"
                      style="font-family: var(--font-sans);"
                    >
                      By {a.data.byline ?? a.data.author}
                    </p>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Order the print edition card -->
  {
    data.order_print && (
      <section class="py-16 md:py-20 px-6 md:px-10">
        <div class="max-w-3xl mx-auto">
          <div class="border border-[var(--color-rust)]/40 bg-[var(--color-cream)] p-8 md:p-12 text-center">
            <SmallCapsLabel tone="rust" items={['The Print Edition']} />
            <h3
              class="mt-4 text-3xl md:text-4xl"
              style="font-variation-settings: 'opsz' 96, 'SOFT' 40, 'WONK' 0;"
            >
              Order the printed issue
            </h3>
            <p
              class="mt-4 text-base md:text-lg text-[var(--color-taupe)] max-w-lg mx-auto"
              style="font-family: var(--font-body);"
            >
              Eighty pages, uncoated stock, shipped in time with the season it
              covers.
              {data.print_price_cents &&
                ` $${(data.print_price_cents / 100).toFixed(0)} plus shipping.`}
            </p>
            <p class="mt-8">
              <a
                href="mailto:hello@abovethehook.com?subject=Order the printed issue"
                class="inline-block px-8 py-3 bg-[var(--color-navy)] text-[var(--color-cream)] text-xs tracking-[0.25em] uppercase no-underline hover:bg-[var(--color-rust)] transition-colors"
                style="font-family: var(--font-sans);"
              >
                Write to us
              </a>
            </p>
            <p
              class="mt-4 text-[0.65rem] tracking-[0.2em] uppercase text-[var(--color-taupe)]/80"
              style="font-family: var(--font-sans);"
            >
              Online checkout opens Phase Two
            </p>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
