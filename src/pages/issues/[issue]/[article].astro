---
/**
 * Article page — /issues/[issue-slug]/[article-slug]
 *
 * Editorial reader. Typography is the point of this template. Spec §4.4.
 */

import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleHeader from '../../../components/ArticleHeader.astro';
import ArticleHeroImage from '../../../components/ArticleHeroImage.astro';
import ArticleHeroPlaceholder from '../../../components/ArticleHeroPlaceholder.astro';
import SmallCapsLabel from '../../../components/SmallCapsLabel.astro';
import Gallery from '../../../components/Gallery.astro';
import CompanionCallout from '../../../components/CompanionCallout.astro';
import StructuredData from '../../../components/StructuredData.astro';
import { articleRoute } from '../../../utils/article-route';
import { getCompanion } from '../../../data/companions';
import { articleSchema, breadcrumbSchema } from '../../../utils/structured-data';

// ── Static paths ──────────────────────────────────────────────────────
// Each article under src/content/articles/[issue]/[article].md becomes
// a route: /issues/[issue]/[article]. Drafts are hidden on production;
// PUBLIC_INCLUDE_DRAFTS is set via Netlify contexts (see netlify.toml).

export async function getStaticPaths() {
  const includeDrafts =
    import.meta.env.PUBLIC_INCLUDE_DRAFTS === 'true' ||
    import.meta.env.DEV === true;

  const all = await getCollection('articles', ({ data }) =>
    includeDrafts ? true : data.status !== 'draft',
  );

  return all.map((article) => {
    const { issueSlug, articleSlug } = articleRoute(article);
    return {
      params: { issue: issueSlug, article: articleSlug },
      props: { article },
    };
  });
}

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content } = await render(article);
const data = article.data;

// ── Related articles (same issue, exclude self, max 3) ─────────────────

const siblings = (await getCollection('articles'))
  .filter((a) => a.data.issue === data.issue && a.id !== article.id)
  .slice(0, 3);

// ── Reading time ──────────────────────────────────────────────────────
const readingTime = data.word_count
  ? `${Math.max(1, Math.round(data.word_count / 220))} min read`
  : undefined;

// ── Drop-cap heuristic ────────────────────────────────────────────────
// Turn drop-cap on for long features; skip editor's letters and short pieces.
const useDropCap = data.type === 'feature';

// ── Issue title for breadcrumb ─────────────────────────────────────────
const issues = await getCollection('issues');
const issue = issues.find((i) => i.id.replace(/\.md$/, '') === data.issue);
const issueTitle = issue?.data.title ?? data.issue;

// ── OG image: sharp-generated composite per article ────────────────────
const ogImageResolved = `/og/${data.issue}/${articleRoute(article).articleSlug}.png`;

// ── Companion artifact (video/podcast/film) ────────────────────────────
const companion = getCompanion(data.companion_to);

// ── Structured data ────────────────────────────────────────────────────
const SITE_ORIGIN = 'https://magazine.abovethehook.com';
const canonicalUrl = `${SITE_ORIGIN}${articleRoute(article).href}`;
const absoluteOgImage = ogImageResolved
  ? new URL(ogImageResolved, SITE_ORIGIN).toString()
  : undefined;
const jsonLd = [
  articleSchema({
    title: data.title,
    description: data.dek || undefined,
    url: canonicalUrl,
    image: absoluteOgImage,
    datePublished: data.publish_date,
    author: data.author,
    pillar: data.pillar,
    tags: data.tags,
    wordCount: data.word_count,
    issueTitle: issueTitle,
  }),
  breadcrumbSchema([
    { name: 'Archive', url: `${SITE_ORIGIN}/archive` },
    { name: issueTitle, url: `${SITE_ORIGIN}/issues/${data.issue}` },
    { name: data.title, url: canonicalUrl },
  ]),
];
---

<BaseLayout
  title={data.title}
  description={data.dek || undefined}
  ogType="article"
  ogImage={ogImageResolved}
  publishedTime={data.publish_date?.toISOString()}
  author={data.author}
  noindex={data.status === 'draft'}
  dataAccess={data.access}
  dataArticleIssue={data.issue}
>
  <StructuredData data={jsonLd} slot="head" />
  <article>
    <!-- Breadcrumb: Issue → Article -->
    <nav
      aria-label="Breadcrumb"
      class="max-w-3xl mx-auto px-6 md:px-10 pt-10"
    >
      <SmallCapsLabel
        items={[issueTitle, `Issue No. ${String(data.issue_number ?? '').padStart(2, '0')}`]}
      />
    </nav>

    <ArticleHeader
      title={data.title}
      dek={data.dek}
      author={data.author}
      byline={data.byline}
      pillar={data.pillar}
      publishDate={data.publish_date}
      readingTime={readingTime}
    />

    {data.hero_image ? (
      <ArticleHeroImage
        src={data.hero_image}
        alt={data.hero_image_alt ?? data.hero_image_caption}
        caption={data.hero_image_caption}
        credit={data.hero_image_credit}
      />
    ) : (
      issue?.data.cover_image && (
        <ArticleHeroPlaceholder
          cover={issue.data.cover_image}
          coverAlt={issue.data.cover_image_alt}
          issueTitle={issue.data.title}
          theme={issue.data.theme}
        />
      )
    )}

    <!-- Body -->
    <div class="px-6 md:px-10 pb-16 md:pb-24">
      <div class:list={['article-prose', useDropCap && 'article-prose--drop-cap']}>
        <Content />
      </div>

      {data.gallery && data.gallery.length > 0 && (
        <Gallery items={data.gallery} title={data.gallery_title ?? 'From the day'} />
      )}

      {companion && <CompanionCallout companion={companion} />}
    </div>

    <!-- End-of-article: tags + related articles from same issue -->
    <footer
      class="max-w-3xl mx-auto px-6 md:px-10 pb-24 border-t border-[var(--color-ink)]/10 pt-10"
    >
      {
        data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-12">
            {data.tags.map((t) => (
              <span class="tag-pill">{t.replace(/_/g, ' ')}</span>
            ))}
          </div>
        )
      }

      {
        siblings.length > 0 && (
          <div>
            <p class="small-caps text-[var(--color-muted)] mb-4">
              <span>More from {issueTitle}</span>
            </p>
            <ul class="list-none m-0 p-0 space-y-6">
              {siblings.map((s) => {
                const { href } = articleRoute(s);
                return (
                  <li>
                    <a
                      href={href}
                      class="block group no-underline"
                    >
                      <span class="small-caps text-[var(--color-rust)]">
                        <span>
                          {s.data.pillar
                            .split('_')
                            .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
                            .join(' ')}
                        </span>
                      </span>
                      <h3
                        class="mt-2 text-2xl md:text-3xl leading-tight text-[var(--color-navy)] group-hover:text-[var(--color-rust)] transition-colors"
                        style="font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
                      >
                        {s.data.title}
                      </h3>
                      {s.data.dek && (
                        <p
                          class="mt-2 text-base leading-snug text-[var(--color-muted)] italic"
                          style="font-family: var(--font-body);"
                        >
                          {s.data.dek}
                        </p>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        )
      }
    </footer>
  </article>
</BaseLayout>
